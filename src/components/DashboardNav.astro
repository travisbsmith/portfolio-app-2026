---
import type { Lead } from '../lib/leads';

export interface Props {
  active: 'clients' | 'analytics' | 'calendar';
  leads?: Lead[];
  currentLeadId?: string;
}
const { active, leads = [], currentLeadId } = Astro.props;
---

<aside class="sidebar">
  <nav class="sidebar-nav">

    <!-- Clients -->
    <div class="sidebar-section">
      <div class="sidebar-row">
        <a
          href="/dashboard"
          class:list={['sidebar-link', { 'sidebar-link--active': active === 'clients' && !currentLeadId }]}
        >Clients</a>
        <button class="sidebar-expand-btn" id="sidebar-clients-toggle" aria-expanded="true" aria-label="Toggle client list" title="Toggle client list">▾</button>
      </div>
      <div class="sidebar-client-list" id="sidebar-client-list">
        {leads.length === 0 ? (
          <span class="sidebar-client-empty">No active clients</span>
        ) : leads.map(lead => (
          <a
            href={`/dashboard/${lead.id}`}
            class:list={['sidebar-client-link', { 'sidebar-client-link--active': lead.id === currentLeadId }]}
          >
            {lead.name}
          </a>
        ))}
      </div>
    </div>

    <!-- Analytics -->
    <a href="/analytics" class:list={['sidebar-link', { 'sidebar-link--active': active === 'analytics' }]}>Analytics</a>

    <!-- Calendar -->
    <a href="/calendar" class:list={['sidebar-link', { 'sidebar-link--active': active === 'calendar' }]}>Calendar</a>

  </nav>

  <div class="sidebar-footer">
    <a href="https://fully-operational.com" class="sidebar-footer-link">← Back to site</a>
    <form method="POST" action="/dashboard" style="margin:0">
      <input type="hidden" name="_action" value="logout" />
      <button type="submit" class="sidebar-footer-link sidebar-logout">Logout</button>
    </form>
  </div>
</aside>

<script>
const toggle = document.getElementById('sidebar-clients-toggle');
const list = document.getElementById('sidebar-client-list');
if (toggle && list) {
  toggle.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    toggle.textContent = !expanded ? '▾' : '▸';
    list.hidden = expanded;
  });
}
</script>

<style>
  .sidebar {
    width: 200px;
    min-width: 200px;
    flex-shrink: 0;
    height: 100vh;
    position: sticky;
    top: 0;
    background: var(--color-bg);
    border-right: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    z-index: 100;
  }

  .sidebar-nav {
    flex: 1;
    padding: var(--space-4) var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .sidebar-section {
    margin-bottom: var(--space-3);
  }

  .sidebar-row {
    display: flex;
    align-items: center;
  }

  .sidebar-link {
    flex: 1;
    display: block;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: all 0.15s;
  }

  .sidebar-link:hover {
    color: var(--color-text);
    background: var(--color-bg-alt);
  }

  .sidebar-link--active {
    color: var(--color-text);
    background: var(--color-bg-alt);
    font-weight: 600;
  }

  .sidebar-expand-btn {
    flex-shrink: 0;
    padding: var(--space-1) var(--space-2);
    background: none;
    border: none;
    color: var(--color-text-tertiary);
    cursor: pointer;
    font-size: var(--text-xs);
    border-radius: var(--radius-sm);
    line-height: 1;
    transition: all 0.15s;
  }

  .sidebar-expand-btn:hover {
    background: var(--color-bg-alt);
    color: var(--color-text);
  }

  .sidebar-client-list {
    margin-top: var(--space-1);
    padding-left: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .sidebar-client-list[hidden] {
    display: none !important;
  }

  .sidebar-client-empty {
    display: block;
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-style: italic;
  }

  .sidebar-client-link {
    display: block;
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: all 0.15s;
  }

  .sidebar-client-link:hover {
    background: var(--color-bg-alt);
    color: var(--color-text);
  }

  .sidebar-client-link--active {
    background: var(--color-bg-alt);
    color: var(--color-text);
    font-weight: 500;
  }

  .sidebar-footer {
    padding: var(--space-4) var(--space-3);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .sidebar-footer-link {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
    text-decoration: none;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    transition: color 0.15s;
  }

  .sidebar-footer-link:hover {
    color: var(--color-accent);
  }

  .sidebar-logout {
    display: block;
    width: 100%;
    text-align: left;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    transition: color 0.15s;
  }

  .sidebar-logout:hover {
    color: var(--color-accent);
  }
</style>
