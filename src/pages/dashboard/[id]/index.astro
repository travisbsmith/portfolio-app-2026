// ── Reminders toggle ──
const reminderBtn = document.getElementById('reminder-toggle-btn');
const reminderStatus = document.getElementById('reminder-toggle-status');
if (reminderBtn && reminderStatus) {
  reminderBtn.addEventListener('click', async () => {
    const isDisabled = reminderBtn.dataset.disabled === 'true';
    const newValue = !isDisabled;
    await patchLead({ remindersDisabled: newValue }, reminderStatus);
    reminderBtn.dataset.disabled = String(newValue);
    reminderBtn.textContent = newValue ? 'Turn reminders on' : 'Turn reminders off';
    const badge = document.querySelector('.reminder-badge');
