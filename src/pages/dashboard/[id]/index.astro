<script define:vars={{
  leadId: lead.id,
  leadEmail: lead.email,
  leadName: lead.name,
  serviceInterest: lead.serviceInterest,
  latestOpenInvoiceUrl: latestOpenInvoice?.hosted_invoice_url ?? '',
  contractHoursPerMonth: contractHours,
  thisMonthPrefix,
  totalHoursAll: totalHours,
  initialActivityLog: lead.activityLog ?? [],
  initialDeliverables: lead.deliverables ?? [],
  isActive,
  showLiveCountdown,
  meetingIso: lead.nextMeetingISO ?? '',
}}>

async function patchLead(patch, statusEl) {
  statusEl.textContent = 'Saving...';
  statusEl.className = 'save-status saving';
  try {
    const res = await fetch('/api/leads/' + leadId, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(patch),
    });
    if (res.ok) {
      statusEl.textContent = 'Saved ✓';
      statusEl.className = 'save-status saved';
      setTimeout(() => { statusEl.textContent = ''; }, 2000);
    } else {
      statusEl.textContent = 'Error';
      statusEl.className = 'save-status error';
    }
  } catch {
    statusEl.textContent = 'Error';
    statusEl.className = 'save-status error';
  }
}

// ── Intake Form toggle (collapsed reference in non-Lead stages) ──
const intakeToggle = document.getElementById('intake-toggle');
const intakeBody = document.getElementById('intake-body');
if (intakeToggle && intakeBody) {
  intakeToggle.addEventListener('click', () => {
    const isOpen = intakeToggle.getAttribute('aria-expanded') === 'true';
    intakeToggle.setAttribute('aria-expanded', String(!isOpen));
    intakeBody.hidden = isOpen;
  });
}

// ── Intake edit form ──
const intakeEditBtn = document.getElementById('intake-edit-btn');
const intakeEditForm = document.getElementById('intake-edit-form');
const intakeCancelBtn = document.getElementById('intake-cancel-btn');
const intakeSaveBtn = document.getElementById('intake-save-btn');
const intakeSaveStatus = document.getElementById('intake-save-status');

if (intakeEditBtn && intakeEditForm && intakeBody) {
  intakeEditBtn.addEventListener('click', () => {
    intakeBody.hidden = true;
    intakeEditForm.hidden = false;
    intakeEditBtn.textContent = 'Editing…';
    intakeEditBtn.disabled = true;
  });

  intakeCancelBtn?.addEventListener('click', () => {
    intakeEditForm.hidden = true;
    intakeBody.hidden = false;
    intakeEditBtn.textContent = 'Edit';
    intakeEditBtn.disabled = false;
    if (intakeSaveStatus) intakeSaveStatus.textContent = '';
  });

  intakeSaveBtn?.addEventListener('click', async () => {
    const patch = {
      storeUrl:        document.getElementById('ie-store-url')?.value ?? '',
      storeStatus:     document.getElementById('ie-store-status')?.value ?? '',
      serviceInterest: document.getElementById('ie-service')?.value ?? '',
      referral:        document.getElementById('ie-referral')?.value ?? '',
      timezone:        document.getElementById('ie-timezone')?.value ?? '',
      launchDate:      document.getElementById('ie-launch-date')?.value ?? '',
      challenge:       document.getElementById('ie-challenge')?.value ?? '',
      additionalNotes: document.getElementById('ie-notes')?.value ?? '',
    };
    await patchLead(patch, intakeSaveStatus);
    // Reflect changes in the display grid without a full reload
    setTimeout(() => location.reload(), 600);
  });
}

// ── Call guide toggle ──
const guideToggle = document.getElementById('guide-toggle');
const guideBody = document.getElementById('guide-body');
if (guideToggle && guideBody) {
  const savedGuideState = localStorage.getItem('guide-open-' + leadId);
  if (savedGuideState === 'true') {
    guideToggle.setAttribute('aria-expanded', 'true');
    guideBody.hidden = false;
  }
  guideToggle.addEventListener('click', () => {
    const isOpen = guideToggle.getAttribute('aria-expanded') === 'true';
    guideToggle.setAttribute('aria-expanded', String(!isOpen));
    guideBody.hidden = isOpen;
    localStorage.setItem('guide-open-' + leadId, String(!isOpen));
  });
}

// ── Stage auto-save ──
const stageSelect = document.getElementById('stage-select');
const stageStatus = document.getElementById('stage-status');

stageSelect.addEventListener('change', async () => {
  await patchLead({ stage: stageSelect.value, completedChecks: [] }, stageStatus);
  location.reload();
});

// ── Notes auto-save ──
const notesTextarea = document.getElementById('notes-textarea');
const notesStatus = document.getElementById('notes-status');
let notesTimer = null;

notesTextarea.addEventListener('input', () => {
  notesStatus.textContent = '';
  clearTimeout(notesTimer);
  notesTimer = setTimeout(() => {
    patchLead({ internalNotes: notesTextarea.value }, notesStatus);
  }, 800);
});

// ── Action panel toggles ──
const btnInvoice = document.getElementById('btn-invoice');
if (btnInvoice) {
  btnInvoice.addEventListener('click', () => {
    const panel = document.getElementById('panel-invoice');
    if (!panel) return;
    // Pre-fill service dropdown from data attrs set server-side
    const prefillService = panel.dataset.service;
    const prefillAmount = panel.dataset.amount;
    if (prefillService) {
      const serviceEl = document.getElementById('inv-service');
      for (const opt of serviceEl.options) {
        if (opt.value === prefillService) { opt.selected = true; break; }
      }
    }
    if (prefillAmount) {
      const firstAmountEl = panel.querySelector('.inv-item-amount');
      if (firstAmountEl && !firstAmountEl.value) firstAmountEl.value = prefillAmount;
    }
    if (prefillService) {
      const firstDescEl = panel.querySelector('.inv-item-desc');
      if (firstDescEl && !firstDescEl.value) {
        const mo = new Date().toLocaleString('en-US', { month: 'long' });
        firstDescEl.value = prefillService.includes('Retainer') ? prefillService + ' — ' + mo : prefillService;
      }
    }
    panel.hidden = !panel.hidden;
  });
}

// Add line item row
const invAddLine = document.getElementById('inv-add-line');
if (invAddLine) {
  invAddLine.addEventListener('click', () => {
    const container = document.getElementById('inv-line-items');
    const idx = container.querySelectorAll('.inv-line-item').length;
    const div = document.createElement('div');
    div.className = 'inv-line-item';
    div.dataset.idx = String(idx);
    div.innerHTML =
      '<div class="form-row"><label>Description</label><input type="text" class="inv-item-desc" placeholder="Additional item" /></div>' +
      '<div class="form-row"><label>Amount (USD)</label><input type="number" class="inv-item-amount" min="1" step="0.01" placeholder="0" /></div>' +
      '<button type="button" class="inv-remove-line btn-sm" style="margin-bottom:var(--space-3)">Remove</button>';
    div.querySelector('.inv-remove-line').addEventListener('click', () => div.remove());
    container.appendChild(div);
  });
}

const btnFollowup = document.getElementById('btn-followup');
if (btnFollowup) {
  btnFollowup.addEventListener('click', () => {
    const firstName = leadName.split(' ')[0];
    const body = latestOpenInvoiceUrl
      ? 'Hi ' + firstName + ',\n\nJust a quick check-in — your invoice is still open.\n\nView and pay here: ' + latestOpenInvoiceUrl + '\n\nLet me know if you have any questions.\n\n— Travis\ntravis@fully-operational.com'
      : 'Hi ' + firstName + ',\n\nJust following up on our conversation — happy to answer any questions or chat more about next steps.\n\nIf you\'d like to book a call: https://cal.com/fullyoperational\n\n— Travis\ntravis@fully-operational.com';
    const fuBody = document.getElementById('fu-body');
    if (fuBody) fuBody.value = body;
    const panel = document.getElementById('panel-followup');
    if (panel) panel.hidden = !panel.hidden;
  });
}

document.querySelectorAll('.btn-cancel').forEach(btn => {
  btn.addEventListener('click', () => {
    const panel = document.getElementById('panel-' + btn.dataset.panel);
    if (panel) panel.hidden = true;
  });
});

// ── Invoice form: preview + confirm flow ──
function getInvoiceLineItems() {
  const items = [];
  document.querySelectorAll('#inv-line-items .inv-line-item').forEach(row => {
    const desc = row.querySelector('.inv-item-desc').value.trim();
    const amt = parseFloat(row.querySelector('.inv-item-amount').value);
    if (desc && amt > 0) items.push({ description: desc, amount: amt });
  });
  return items;
}

const btnPreviewInvoice = document.getElementById('btn-preview-invoice');
const btnConfirmInvoice = document.getElementById('btn-confirm-invoice');
const invoicePreviewEl = document.getElementById('invoice-preview');

if (btnPreviewInvoice) {
  btnPreviewInvoice.addEventListener('click', () => {
    const feedback = document.getElementById('invoice-feedback');
    const lineItems = getInvoiceLineItems();
    if (lineItems.length === 0) {
      feedback.textContent = 'Add at least one line item with description and amount.';
      feedback.className = 'form-feedback error';
      return;
    }
    const service = document.getElementById('inv-service').value;
    const total = lineItems.reduce((s, i) => s + i.amount, 0);
    let html = '<strong>Invoice preview</strong><br>';
    html += '<span style="font-size:var(--text-xs);color:var(--color-text-tertiary)">Service: ' + service + '</span><br><br>';
    lineItems.forEach(item => {
      html += '<div style="display:flex;justify-content:space-between;font-size:var(--text-sm)">' +
        '<span>' + item.description.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</span>' +
        '<span>$' + item.amount.toFixed(2) + '</span></div>';
    });
    html += '<hr style="margin:var(--space-2) 0;border-color:var(--color-border)">';
    html += '<div style="display:flex;justify-content:space-between;font-weight:700;font-size:var(--text-sm)"><span>Total</span><span>$' + total.toFixed(2) + '</span></div>';
    invoicePreviewEl.innerHTML = html;
    invoicePreviewEl.hidden = false;
    btnPreviewInvoice.hidden = true;
    btnConfirmInvoice.hidden = false;
    feedback.textContent = '';
    feedback.className = 'form-feedback';
  });
}

const invoiceFormEl = document.getElementById('invoice-form');
invoiceFormEl && invoiceFormEl.addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = document.getElementById('btn-confirm-invoice');
  const feedback = document.getElementById('invoice-feedback');
  btn.disabled = true; btn.textContent = 'Sending…';
  feedback.textContent = ''; feedback.className = 'form-feedback';
  try {
    const lineItems = getInvoiceLineItems();
    const res = await fetch('/api/stripe/invoice', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        leadId,
        clientName: leadName,
        clientEmail: leadEmail,
        service: document.getElementById('inv-service').value,
        lineItems,
      }),
    });
    const json = await res.json();
    if (res.ok) {
      feedback.textContent = 'Invoice sent ✓';
      feedback.className = 'form-feedback success';
      setTimeout(() => location.reload(), 1500);
    } else {
      feedback.textContent = json.error || 'Something went wrong';
      feedback.className = 'form-feedback error';
      btn.disabled = false; btn.textContent = 'Confirm & Send';
    }
  } catch {
    feedback.textContent = 'Network error';
    feedback.className = 'form-feedback error';
    btn.disabled = false; btn.textContent = 'Confirm & Send';
  }
});

// ── Follow-up form ──
const followupFormEl = document.getElementById('followup-form');
followupFormEl && followupFormEl.addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = e.target.querySelector('.btn-send');
  const feedback = document.getElementById('followup-feedback');
  btn.disabled = true; btn.textContent = 'Sending…';
  feedback.textContent = ''; feedback.className = 'form-feedback';
  const body = document.getElementById('fu-body').value;
  const html = body.split('\n').map(l => '<p>' + (l || '&nbsp;') + '</p>').join('');
  try {
    const res = await fetch('/api/email/send', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ to: leadEmail, subject: document.getElementById('fu-subject').value, html }),
    });
    const json = await res.json();
    if (res.ok) {
      feedback.textContent = 'Email sent ✓';
      feedback.className = 'form-feedback success';
      setTimeout(() => { document.getElementById('panel-followup').hidden = true; feedback.textContent = ''; }, 1500);
    } else {
      feedback.textContent = json.error || 'Something went wrong';
      feedback.className = 'form-feedback error';
    }
  } catch {
    feedback.textContent = 'Network error';
    feedback.className = 'form-feedback error';
  } finally {
    btn.disabled = false; btn.textContent = 'Send Email';
  }
});

// ── Next Meeting / Stripe ID save ──
const nextMeetingSave = document.getElementById('next-meeting-save');
nextMeetingSave && nextMeetingSave.addEventListener('click', () =>
  patchLead({ nextMeeting: document.getElementById('next-meeting-input').value },
    document.getElementById('next-meeting-status'))
);

const stripeIdSave = document.getElementById('stripe-id-save');
stripeIdSave && stripeIdSave.addEventListener('click', () =>
  patchLead({ stripeCustomerId: document.getElementById('stripe-customer-id').value },
    document.getElementById('stripe-id-status'))
);

// ── Stage Checklist ──
document.querySelectorAll('#stage-checklist .check-input').forEach(cb => {
  cb.addEventListener('change', () => {
    const checked = [...document.querySelectorAll('#stage-checklist .check-input')]
      .filter(c => c.checked)
      .map(c => c.dataset.item);
    patchLead({ completedChecks: checked }, document.getElementById('checklist-status'));
    // Update strikethrough style immediately
    cb.closest('.checklist-item').querySelector('.check-label').classList.toggle('check-label--done', cb.checked);
  });
});

// ── Time tracking ──
const timeForm = document.getElementById('time-form');
const timeFeedback = document.getElementById('time-feedback');
const timeMonthLabel = document.getElementById('time-month-label');

function getMonthly() {
  let total = 0;
  document.querySelectorAll('.time-entry').forEach(entry => {
    const dateEl = entry.querySelector('.time-entry__date');
    const hoursEl = entry.querySelector('.time-entry__hours');
    if (dateEl && dateEl.textContent && dateEl.textContent.startsWith(thisMonthPrefix) && hoursEl) {
      total += parseFloat(hoursEl.textContent) || 0;
    }
  });
  return total;
}

function getTotal() {
  let total = 0;
  document.querySelectorAll('.time-entry').forEach(entry => {
    const hoursEl = entry.querySelector('.time-entry__hours');
    if (hoursEl) total += parseFloat(hoursEl.textContent) || 0;
  });
  return total;
}

function updateTimeLabel() {
  if (!timeMonthLabel) return;
  const month = getMonthly();
  const total = getTotal();
  let text = contractHoursPerMonth
    ? month.toFixed(1) + ' / ' + contractHoursPerMonth + ' hrs this month'
    : month.toFixed(1) + ' hrs this month';
  if (total > month) text += ' · ' + total.toFixed(1) + ' total';
  timeMonthLabel.textContent = text;
}

function updateDescSuggestions() {
  const datalist = document.getElementById('time-desc-list');
  if (!datalist) return;
  datalist.innerHTML = '';
  const seen = new Set();
  document.querySelectorAll('.time-entry__desc').forEach(el => {
    const text = el.textContent && el.textContent.trim();
    if (text && text !== '—' && !seen.has(text)) {
      seen.add(text);
      const opt = document.createElement('option');
      opt.value = text;
      datalist.appendChild(opt);
    }
  });
}

updateDescSuggestions();

function attachDeleteHandler(btn) {
  btn.addEventListener('click', async () => {
    const entryId = btn.dataset.entryId;
    btn.textContent = '…';
    try {
      const res = await fetch('/api/time/' + leadId, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ entryId }),
      });
      if (res.ok) {
        btn.closest('.time-entry').remove();
        updateTimeLabel();
        updateDescSuggestions();
        if (document.querySelectorAll('.time-entry').length === 0) {
          const empty = document.createElement('p');
          empty.className = 'empty';
          empty.id = 'time-empty';
          empty.textContent = 'No time logged yet.';
          const list = document.querySelector('.time-list');
          if (list) list.replaceWith(empty);
        }
      } else {
        btn.textContent = '×';
      }
    } catch {
      btn.textContent = '×';
    }
  });
}

document.querySelectorAll('.time-entry__delete').forEach(attachDeleteHandler);

timeForm && timeForm.addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = document.getElementById('time-submit');
  btn.disabled = true;
  timeFeedback.textContent = '';

  const date = timeForm.elements.namedItem('date').value;
  const hours = parseFloat(timeForm.elements.namedItem('hours').value);
  const description = timeForm.elements.namedItem('description').value.trim();

  try {
    const res = await fetch('/api/time/' + leadId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ date, hours, description }),
    });
    const entry = await res.json();
    if (!res.ok) throw new Error(entry.error || 'Failed');

    const row = document.createElement('div');
    row.className = 'time-entry';
    row.dataset.entryId = entry.id;
    row.innerHTML =
      '<div class="time-entry__date">' + entry.date + '</div>' +
      '<div class="time-entry__hours">' + entry.hours + 'h</div>' +
      '<div class="time-entry__desc">' + (entry.description || '—') + '</div>' +
      '<button class="time-entry__delete" data-entry-id="' + entry.id + '" aria-label="Delete">×</button>';
    attachDeleteHandler(row.querySelector('.time-entry__delete'));

    const existingList = document.getElementById('time-list');
    if (existingList) {
      existingList.insertAdjacentElement('afterbegin', row);
    } else {
      const list = document.createElement('div');
      list.className = 'time-list';
      list.id = 'time-list';
      list.appendChild(row);
      const empty = document.getElementById('time-empty');
      if (empty) empty.replaceWith(list);
    }

    updateTimeLabel();
    updateDescSuggestions();
    timeForm.elements.namedItem('description').value = '';
  } catch (err) {
    timeFeedback.textContent = (err && err.message) || 'Error logging time';
    timeFeedback.className = 'form-feedback error';
  } finally {
    btn.disabled = false;
  }
});

// ── Activity Log ──
let activityLog = initialActivityLog.slice();
const activityStatus = document.getElementById('activity-status');

function renderActivityEntry(entry) {
  const div = document.createElement('div');
  div.className = 'activity-entry';
  div.dataset.entryId = entry.id;
  const typeClass = 'activity-badge activity-badge--' + entry.type.toLowerCase();
  const dateStr = new Date(entry.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  div.innerHTML =
    '<div class="activity-entry__meta">' +
      '<span class="' + typeClass + '">' + entry.type + '</span>' +
      '<span class="activity-entry__date">' + dateStr + '</span>' +
      '<button class="activity-entry__delete" data-entry-id="' + entry.id + '" aria-label="Delete">&times;</button>' +
    '</div>' +
    '<div class="activity-entry__text">' + entry.text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</div>';
  div.querySelector('.activity-entry__delete').addEventListener('click', () => deleteActivityEntry(entry.id));
  return div;
}

function attachActivityDeleteHandlers() {
  document.querySelectorAll('.activity-entry__delete').forEach(btn => {
    btn.addEventListener('click', () => deleteActivityEntry(btn.dataset.entryId));
  });
}
attachActivityDeleteHandlers();

async function deleteActivityEntry(entryId) {
  const res = await fetch('/api/activity/' + leadId, {
    method: 'DELETE',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ entryId }),
  });
  if (!res.ok) { activityStatus.textContent = 'Error'; activityStatus.className = 'save-status error'; return; }
  activityLog = activityLog.filter(e => e.id !== entryId);
  const el = document.querySelector('.activity-entry[data-entry-id="' + entryId + '"]');
  if (el) el.remove();
  if (activityLog.length === 0) {
    const list = document.getElementById('activity-list');
    if (list) list.innerHTML = '<p class="empty" id="activity-empty">No activity logged yet.</p>';
  }
}

const activityForm = document.getElementById('activity-form');
activityForm && activityForm.addEventListener('submit', async (e) => {
  e.preventDefault();
  const type = document.getElementById('activity-type').value;
  const text = document.getElementById('activity-text').value.trim();
  if (!text) return;

  activityStatus.textContent = 'Saving...';
  activityStatus.className = 'save-status saving';
  const res = await fetch('/api/activity/' + leadId, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ type, text }),
  });
  if (!res.ok) { activityStatus.textContent = 'Error'; activityStatus.className = 'save-status error'; return; }
  const entry = await res.json();
  activityLog.unshift(entry);
  activityStatus.textContent = 'Saved ✓';
  activityStatus.className = 'save-status saved';
  setTimeout(() => { activityStatus.textContent = ''; }, 2000);

  const list = document.getElementById('activity-list');
  const empty = document.getElementById('activity-empty');
  if (empty) empty.remove();
  if (list) list.insertAdjacentElement('afterbegin', renderActivityEntry(entry));

  document.getElementById('activity-text').value = '';
});

// ── Deliverables ──
if (isActive) {
  let deliverables = initialDeliverables.slice();
  const deliverablesStatus = document.getElementById('deliverables-status');

  function renderDeliverable(item) {
    const div = document.createElement('div');
    div.className = 'deliverable-item';
    div.dataset.itemId = item.id;
    div.dataset.status = item.status;
    const icon = item.status === 'done' ? '✓' : item.status === 'in-progress' ? '◑' : '○';
    const titleClass = 'deliverable-title-text' + (item.status === 'done' ? ' deliverable-title-text--done' : '');
    div.innerHTML =
      '<button class="deliverable-status-btn deliverable-status-btn--' + item.status + '" data-item-id="' + item.id + '" aria-label="Toggle status">' + icon + '</button>' +
      '<span class="' + titleClass + '">' + item.title.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</span>' +
      '<button class="deliverable-delete-btn" data-item-id="' + item.id + '" aria-label="Delete">&times;</button>';
    attachDeliverableHandlers(div);
    return div;
  }

  const STATUS_CYCLE = { 'pending': 'in-progress', 'in-progress': 'done', 'done': 'pending' };

  function showDelStatus(msg, cls) {
    deliverablesStatus.textContent = msg;
    deliverablesStatus.className = 'save-status ' + cls;
    if (cls === 'saved') setTimeout(() => { deliverablesStatus.textContent = ''; }, 2000);
  }

  function attachDeliverableHandlers(container) {
    container.querySelector('.deliverable-status-btn').addEventListener('click', async () => {
      const itemId = container.querySelector('.deliverable-status-btn').dataset.itemId;
      const item = deliverables.find(d => d.id === itemId);
      if (!item) return;
      const newStatus = STATUS_CYCLE[item.status] || 'pending';
      showDelStatus('Saving...', 'saving');
      const res = await fetch('/api/deliverables/' + leadId, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ itemId, status: newStatus }),
      });
      if (!res.ok) { showDelStatus('Error', 'error'); return; }
      item.status = newStatus;
      showDelStatus('Saved ✓', 'saved');
      const fresh = renderDeliverable(item);
      container.replaceWith(fresh);
    });
    container.querySelector('.deliverable-delete-btn').addEventListener('click', async () => {
      const itemId = container.querySelector('.deliverable-delete-btn').dataset.itemId;
      showDelStatus('Saving...', 'saving');
      const res = await fetch('/api/deliverables/' + leadId, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ itemId }),
      });
      if (!res.ok) { showDelStatus('Error', 'error'); return; }
      deliverables = deliverables.filter(d => d.id !== itemId);
      showDelStatus('Saved ✓', 'saved');
      container.remove();
      if (deliverables.length === 0) {
        const list = document.getElementById('deliverable-list');
        if (list) list.innerHTML = '<p class="empty" id="deliverable-empty">No deliverables defined yet.</p>';
      }
    });
  }

  document.querySelectorAll('.deliverable-item').forEach(attachDeliverableHandlers);

  const deliverableForm = document.getElementById('deliverable-form');
  deliverableForm && deliverableForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const titleInput = document.getElementById('deliverable-title');
    const title = titleInput.value.trim();
    if (!title) return;

    showDelStatus('Saving...', 'saving');
    const res = await fetch('/api/deliverables/' + leadId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title }),
    });
    if (!res.ok) { showDelStatus('Error', 'error'); return; }
    const item = await res.json();
    deliverables.push(item);
    showDelStatus('Saved ✓', 'saved');

    const list = document.getElementById('deliverable-list');
    const empty = document.getElementById('deliverable-empty');
    if (empty) empty.remove();
    if (list) list.appendChild(renderDeliverable(item));
    titleInput.value = '';
  });
}

// ── Contract signed ──
const contractSignBtn = document.getElementById('contract-sign-btn');
if (contractSignBtn) {
  contractSignBtn.addEventListener('click', async () => {
    contractSignBtn.disabled = true;
    contractSignBtn.textContent = 'Saving…';
    const contractStatus = document.getElementById('contract-status');
    await patchLead({ contractSignedAt: new Date().toISOString() }, contractStatus);
    location.reload();
  });
}

// ── Retainer "Send Now" shortcut ──
const btnSendRetainerInvoice = document.getElementById('btn-send-retainer-invoice');
if (btnSendRetainerInvoice) {
  btnSendRetainerInvoice.addEventListener('click', () => {
    // Open invoice panel with retainer pre-fill
    const panel = document.getElementById('panel-invoice');
    const btnInv = document.getElementById('btn-invoice');
    if (panel) {
      if (btnInv) btnInv.click(); // triggers pre-fill + toggle
      else panel.hidden = false;
    }
    panel?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
}

// ── Countdown live tick (only when meeting is < 48h away) ──
if (showLiveCountdown && meetingIso) {
  const countdownEl = document.getElementById('countdown-display');
  if (countdownEl) {
    function updateCountdown() {
      const ms = new Date(meetingIso).getTime() - Date.now();
      if (ms <= 0) { countdownEl.textContent = 'Now or past'; return; }
      const h = Math.floor(ms / 3600000);
      const m = Math.floor((ms % 3600000) / 60000);
      const s = Math.floor((ms % 60000) / 1000);
      countdownEl.textContent = h > 0
        ? `${h}h ${String(m).padStart(2,'0')}m`
        : `${m}m ${String(s).padStart(2,'0')}s`;
    }
    updateCountdown();
    setInterval(updateCountdown, 1000);
  }
}

// ── Closed proposal collapsible toggle ──
const closedProposalToggle = document.getElementById('closed-proposal-toggle');
const closedProposalBody = document.getElementById('closed-proposal-body');
if (closedProposalToggle && closedProposalBody) {
  closedProposalToggle.addEventListener('click', () => {
    const expanded = closedProposalToggle.getAttribute('aria-expanded') === 'true';
    closedProposalToggle.setAttribute('aria-expanded', String(!expanded));
    closedProposalBody.hidden = expanded;
    const arrow = closedProposalToggle.querySelector('.toggle-arrow');
    if (arrow) arrow.textContent = expanded ? '▶' : '▼';
  });
}

// ── Cancel Call ──
const btnCancelCall = document.getElementById('btn-cancel-call');
if (btnCancelCall) {
  btnCancelCall.addEventListener('click', async () => {
    if (!confirm('Cancel this call on Cal.com and revert the lead to Lead stage?')) return;
    const statusEl = document.getElementById('cancel-call-status');
    btnCancelCall.disabled = true;
    btnCancelCall.textContent = 'Cancelling…';
    if (statusEl) { statusEl.textContent = 'Cancelling…'; statusEl.className = 'save-status saving'; }
    try {
      const res = await fetch('/api/cal/cancel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ leadId }),
      });
      if (res.ok) {
        if (statusEl) { statusEl.textContent = 'Cancelled ✓'; statusEl.className = 'save-status saved'; }
        setTimeout(() => location.reload(), 800);
      } else {
        const json = await res.json().catch(() => ({}));
        if (statusEl) { statusEl.textContent = json.error ?? 'Error'; statusEl.className = 'save-status error'; }
        btnCancelCall.disabled = false;
        btnCancelCall.textContent = 'Cancel Call';
      }
    } catch {
      if (statusEl) { statusEl.textContent = 'Network error'; statusEl.className = 'save-status error'; }
      btnCancelCall.disabled = false;
      btnCancelCall.textContent = 'Cancel Call';
    }
  });
}

// ── Proposal summary: Send Follow-up ──
const btnFollowupSummary = document.getElementById('btn-followup-summary');
if (btnFollowupSummary) {
  btnFollowupSummary.addEventListener('click', () => {
    // Open the follow-up panel in the sidebar
    const panelFollowup = document.getElementById('panel-followup');
    const btnFollowupToggle = document.getElementById('btn-followup');
    if (panelFollowup && btnFollowupToggle) {
      panelFollowup.hidden = false;
      btnFollowupToggle.setAttribute('aria-expanded', 'true');
      panelFollowup.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  });
}
</script>
