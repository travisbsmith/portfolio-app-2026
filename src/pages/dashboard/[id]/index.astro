      feedback.textContent = 'Invoice sent ✓';
      feedback.className = 'form-feedback success';
      setTimeout(() => location.reload(), 1500);
    } else {
      feedback.textContent = json.error || 'Something went wrong';
      feedback.className = 'form-feedback error';
      btn.disabled = false; btn.textContent = 'Confirm & Send';
    }
  } catch {
    feedback.textContent = 'Network error';
    feedback.className = 'form-feedback error';
    btn.disabled = false; btn.textContent = 'Confirm & Send';
  }
});

// ── Follow-up form ──
const followupFormEl = document.getElementById('followup-form');
followupFormEl && followupFormEl.addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = e.target.querySelector('.btn-send');
  const feedback = document.getElementById('followup-feedback');
  btn.disabled = true; btn.textContent = 'Sending…';
  feedback.textContent = ''; feedback.className = 'form-feedback';
  const body = document.getElementById('fu-body').value;
  const html = body.split('\n').map(l => '<p>' + (l || '&nbsp;') + '</p>').join('');
  try {
    const res = await fetch('/api/email/send', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ to: leadEmail, subject: document.getElementById('fu-subject').value, html }),
    });
    const json = await res.json();
    if (res.ok) {
      feedback.textContent = 'Email sent ✓';
      feedback.className = 'form-feedback success';
      setTimeout(() => { document.getElementById('panel-followup').hidden = true; feedback.textContent = ''; }, 1500);
    } else {
      feedback.textContent = json.error || 'Something went wrong';
      feedback.className = 'form-feedback error';
    }
  } catch {
    feedback.textContent = 'Network error';
    feedback.className = 'form-feedback error';
  } finally {
    btn.disabled = false; btn.textContent = 'Send Email';
  }
});

