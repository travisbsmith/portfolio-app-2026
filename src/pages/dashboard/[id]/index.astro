async function patchLead(patch, statusEl) {
  statusEl.textContent = 'Saving...';
  statusEl.className = 'save-status saving';
  try {
    const res = await fetch('/api/leads/' + leadId, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(patch),
    });
    if (res.ok) {
      statusEl.textContent = 'Saved ✓';
      statusEl.className = 'save-status saved';
      setTimeout(() => { statusEl.textContent = ''; }, 2000);
    } else {
      statusEl.textContent = 'Error';
      statusEl.className = 'save-status error';
    }
  } catch {
    statusEl.textContent = 'Error';
    statusEl.className = 'save-status error';
  }
}

// ── Markdown toolbar helper ──
function setupToolbar(toolbar, textarea) {
  if (!toolbar || !textarea) return;
  toolbar.querySelectorAll('.md-btn[data-action]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const action = btn.dataset.action;
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const sel = textarea.value.slice(start, end);
      const before = textarea.value.slice(0, start);
      const after = textarea.value.slice(end);
      let replacement = '';
      let cursorOffset = 0;

      if (action === 'bold') {
        replacement = sel ? `**${sel}**` : '****';
        cursorOffset = sel ? replacement.length : 2;
      } else if (action === 'italic') {
        replacement = sel ? `_${sel}_` : '__';
        cursorOffset = sel ? replacement.length : 1;
      } else if (action === 'link') {
        const url = prompt('URL:') || 'https://';
        replacement = sel ? `[${sel}](${url})` : `[](${url})`;
        cursorOffset = sel ? replacement.length : 1;
      } else if (action === 'code') {
        replacement = sel ? `\`${sel}\`` : '``';
        cursorOffset = sel ? replacement.length : 1;
      } else if (action === 'heading') {
        const lineStart = before.lastIndexOf('\n') + 1;
        const lineContent = textarea.value.slice(lineStart, end || textarea.value.length);
        if (lineContent.startsWith('## ')) {
          textarea.value = textarea.value.slice(0, lineStart) + lineContent.slice(3) + after;
          textarea.setSelectionRange(start - 3, end - 3);
        } else {
          textarea.value = textarea.value.slice(0, lineStart) + '## ' + lineContent.replace(/^#+\s*/, '') + after;
          textarea.setSelectionRange(start + 3, end + 3);
        }
        textarea.dispatchEvent(new Event('input'));
        textarea.focus();
        return;
      } else if (action === 'list') {
        const lineStart = before.lastIndexOf('\n') + 1;
        const lineContent = textarea.value.slice(lineStart);
        if (lineContent.startsWith('- ')) {
          textarea.value = textarea.value.slice(0, lineStart) + lineContent.slice(2);
          textarea.setSelectionRange(start - 2, end - 2);
        } else {
          textarea.value = textarea.value.slice(0, lineStart) + '- ' + lineContent;
          textarea.setSelectionRange(start + 2, end + 2);
        }
        textarea.dispatchEvent(new Event('input'));
        textarea.focus();
        return;
      }

      textarea.value = before + replacement + after;
      const newCursor = start + cursorOffset;
      textarea.setSelectionRange(newCursor, newCursor);
      textarea.dispatchEvent(new Event('input'));
      textarea.focus();
    });
  });
}

