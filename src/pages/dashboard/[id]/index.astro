const invoicePreviewEl = document.getElementById('invoice-preview');

if (btnPreviewInvoice) {
  btnPreviewInvoice.addEventListener('click', () => {
    const feedback = document.getElementById('invoice-feedback');
    const lineItems = getInvoiceLineItems();
    if (lineItems.length === 0) {
      feedback.textContent = 'Add at least one line item with description and amount.';
      feedback.className = 'form-feedback error';
      return;
    }
    const service = document.getElementById('inv-service').value;
    const total = lineItems.reduce((s, i) => s + i.amount, 0);
    let html = '<strong>Invoice preview</strong><br>';
    html += '<span style="font-size:var(--text-xs);color:var(--color-text-tertiary)">Service: ' + service + '</span><br><br>';
    lineItems.forEach(item => {
      html += '<div style="display:flex;justify-content:space-between;font-size:var(--text-sm)">' +
        '<span>' + item.description.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</span>' +
        '<span>$' + item.amount.toFixed(2) + '</span></div>';
    });
    html += '<hr style="margin:var(--space-2) 0;border-color:var(--color-border)">';
    html += '<div style="display:flex;justify-content:space-between;font-weight:700;font-size:var(--text-sm)"><span>Total</span><span>$' + total.toFixed(2) + '</span></div>';
    invoicePreviewEl.innerHTML = html;
    invoicePreviewEl.hidden = false;
    btnPreviewInvoice.hidden = true;
    btnConfirmInvoice.hidden = false;
    feedback.textContent = '';
    feedback.className = 'form-feedback';
  });
}

