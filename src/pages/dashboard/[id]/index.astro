---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import DashboardNav from '../../../components/DashboardNav.astro';
import { getLeads, type ActivityEntry, type Deliverable, type TodoItem } from '../../../lib/leads';
import { marked } from 'marked';
import { isAuthenticated } from '../../../lib/auth';
import { getTimeEntries, type TimeEntry } from '../../../lib/time';
import { matchService, STAGE_CHECKLISTS } from '../../../lib/services';
import Stripe from 'stripe';

if (!isAuthenticated(Astro.cookies)) return Astro.redirect('/dashboard');

// Load lead
const { id } = Astro.params;
const leads = await getLeads();
const lead = leads.find(l => l.id === id);
if (!lead) return Astro.redirect('/dashboard');

// Load Stripe invoices
let invoices: any[] = [];
if (lead.stripeCustomerId) {
  try {
    const stripe = new Stripe(import.meta.env.STRIPE_SECRET_KEY ?? process.env.STRIPE_SECRET_KEY ?? '');
    const result = await stripe.invoices.list({ customer: lead.stripeCustomerId, limit: 25 });
    invoices = result.data;
  } catch { /* Stripe not configured */ }
}

// Find latest open invoice URL for follow-up pre-fill
const latestOpenInvoice = invoices.find(inv => inv.status === 'open');

// Time tracking
const timeEntries = await getTimeEntries(lead.id);
const serviceConfig = matchService(lead.serviceInterest ?? '');
const contractHours = serviceConfig?.contractHoursPerMonth ?? null;
const now = new Date();
const thisMonthPrefix = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;
const monthlyHours = timeEntries
  .filter(e => e.date.startsWith(thisMonthPrefix))
  .reduce((sum, e) => sum + e.hours, 0);
const totalHours = timeEntries.reduce((sum, e) => sum + e.hours, 0);

// Stage-aware derived values
const checklist = STAGE_CHECKLISTS[lead.stage] ?? [];
const completedChecks = lead.completedChecks ?? [];
const isPreCall = lead.stage === 'Lead' || lead.stage === 'Call Scheduled';
const isProposal = lead.stage === 'Proposal Sent';
const isActive = lead.stage === 'Active';
const isClosed = lead.stage === 'Closed' || lead.stage === 'Archived';

const phaseLabel = isActive ? 'Active' : isProposal ? 'Proposal' : isClosed ? 'Closed' : 'Pre-Call';
const phaseColor = isActive ? '#38a169' : isProposal ? '#d69e2e' : 'var(--color-text-tertiary)';

// Phase context computed values
const daysSinceLead = Math.floor((Date.now() - new Date(lead.createdAt).getTime()) / (1000 * 60 * 60 * 24));
const latestInvoice = invoices[0] ?? null;
const latestInvoiceStatus = latestInvoice?.status ?? null;
const latestInvoiceAmount = latestInvoice ? `$${Math.round((latestInvoice.amount_due ?? 0) / 100)}` : null;

// Call Scheduled: countdown to next meeting
const meetingMs = lead.nextMeetingISO ? new Date(lead.nextMeetingISO).getTime() : null;
const msUntilMeeting = meetingMs ? meetingMs - Date.now() : null;
const daysUntilMeeting = msUntilMeeting !== null ? Math.floor(msUntilMeeting / 86400000) : null;
const hoursUntilMeeting = msUntilMeeting !== null ? Math.floor(msUntilMeeting / 3600000) : null;
const showLiveCountdown = hoursUntilMeeting !== null && hoursUntilMeeting >= 0 && hoursUntilMeeting < 48;
const countdownLabel = daysUntilMeeting !== null && daysUntilMeeting > 0
  ? `${daysUntilMeeting}d ${hoursUntilMeeting! % 24}h away`
  : hoursUntilMeeting !== null && hoursUntilMeeting > 0
    ? `${hoursUntilMeeting}h away`
    : hoursUntilMeeting !== null && hoursUntilMeeting <= 0
      ? 'Now or past'
      : 'Scheduled';

// Next Action banner computed values
const deliverablesInProgress = (lead.deliverables ?? []).filter(d => d.status !== 'done').length;

// Unified work feed (activity log + time entries merged by date, newest first)
type FeedItem =
  | { kind: 'activity'; data: ActivityEntry; sortKey: string }
  | { kind: 'time'; data: TimeEntry; sortKey: string };

const feedItems: FeedItem[] = [
  ...(lead.activityLog ?? []).map(e => ({ kind: 'activity' as const, data: e, sortKey: e.createdAt })),
  ...timeEntries.map(e => ({ kind: 'time' as const, data: e, sortKey: e.date + 'T23:59:59Z' })),
].sort((a, b) => b.sortKey.localeCompare(a.sortKey));

// Proposal Sent: days since proposal
const proposalSentAt = lead.proposalSentAt ?? lead.updatedAt;
const daysSinceProposal = Math.floor((Date.now() - new Date(proposalSentAt).getTime()) / 86400000);

// Closed: timeline and reconnect prompt
const monthsAsClient = Math.max(1, Math.round((Date.now() - new Date(lead.createdAt).getTime()) / (1000 * 60 * 60 * 24 * 30)));
const closedReferenceDate = lead.contractSignedAt ?? lead.updatedAt;
const reconnectDate = new Date(new Date(closedReferenceDate).getTime() + 90 * 86400000)
  .toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const totalPaid = invoices.reduce((s: number, inv: any) => s + ((inv.amount_paid ?? 0) / 100), 0);

// Retainer billing status (Active retainer clients only)
const isRetainer = serviceConfig?.isRecurring === true;
const billingMonthStart = new Date(now.getFullYear(), now.getMonth(), 1).getTime() / 1000; // unix seconds
const thisMonthInvoice = isActive && isRetainer
  ? invoices.find((inv: any) => inv.created >= billingMonthStart) ?? null
  : null;

// Current month label for "this month" badge on invoice list
const currentMonthLabel = now.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

// Sidebar: last activity
const lastActivity = lead.activityLog?.[0] ?? null;
const lastActivityDaysAgo = lastActivity
  ? Math.floor((Date.now() - new Date(lastActivity.createdAt).getTime()) / 86400000)
  : null;
---

<BaseLayout title={`${lead.name} — Dashboard`} description="Lead detail">
<div class="lead-page app-layout">

  <DashboardNav active="clients" leads={leads.filter(l => l.stage !== 'Archived')} currentLeadId={lead.id} />

  <div class="app-main">

  <!-- ── Header ── -->
  <header class="lead-header">
    <div class="container">
      <div class="lead-header__inner">
        <div class="lead-header__left">
          <div class="lead-header__title">
            <h1>{lead.name}</h1>
            <a href={`mailto:${lead.email}`} class="lead-email">{lead.email}</a>
            {lead.storeUrl && (
              <a href={lead.storeUrl} target="_blank" rel="noopener" class="lead-store">
                {lead.storeUrl.replace(/^https?:\/\//, '')} ↗
              </a>
            )}
          </div>
        </div>
        <div class="lead-header__right">
          <span class="phase-badge" style={`--phase-color: ${phaseColor}`}>{phaseLabel}</span>
          <select id="stage-select" class="stage-select" data-lead-id={lead.id} data-current={lead.stage}>
            {['Lead','Call Scheduled','Proposal Sent','Active','Closed'].map(s => (
              <option value={s} selected={s === lead.stage}>{s}</option>
            ))}
          </select>
          <span id="stage-status" class="save-status"></span>
        </div>
      </div>
    </div>
  </header>

  <!-- ── Body ── -->
  <div class="lead-body container">
    <div class="lead-main">

      <!-- ── Phase Status Bar ── -->
      <div class="phase-bar phase-bar--{lead.stage.toLowerCase().replace(/\s+/g,'-')}">
        {lead.stage === 'Lead' && (
          <>
            <span class="phase-bar__label">New lead</span>
            {lead.referral && <span class="phase-bar__detail">via {lead.referral}</span>}
            <span class="phase-bar__dot">·</span>
            <span class="phase-bar__detail">{daysSinceLead === 0 ? 'today' : `${daysSinceLead}d ago`}</span>
            <span class="phase-bar__dot">·</span>
            <span class="phase-bar__detail">{lead.serviceInterest ? lead.serviceInterest.replace(/\s*\(\$[\d,]+(?:\/\w+)?\)/g,'') : 'service unknown'}</span>
            <a href={`/dashboard/${lead.id}/proposal`} class="phase-bar__cta">Send Proposal →</a>
          </>
        )}
        {lead.stage === 'Call Scheduled' && (
          <>
            <span class="phase-bar__label">Call scheduled</span>
            {lead.nextMeeting
              ? <span class="phase-bar__meeting">{lead.nextMeeting}</span>
              : <span class="phase-bar__detail phase-bar__detail--warn">No time set yet</span>
            }
          </>
        )}
        {lead.stage === 'Proposal Sent' && (
          <>
            <span class="phase-bar__label">Proposal sent</span>
            <span class="phase-bar__detail">{daysSinceLead === 0 ? 'today' : `${daysSinceLead}d ago`}</span>
            {latestInvoiceStatus && (
              <>
                <span class="phase-bar__dot">·</span>
                <span class={`phase-bar__invoice-status phase-bar__invoice-status--${latestInvoiceStatus}`}>
                  Invoice: {latestInvoiceStatus}{latestInvoiceAmount ? ` ${latestInvoiceAmount}` : ''}
                </span>
              </>
            )}
            {!latestInvoiceStatus && (
              <>
                <span class="phase-bar__dot">·</span>
                <span class="phase-bar__detail phase-bar__detail--warn">No invoice yet</span>
              </>
            )}
          </>
        )}
        {lead.stage === 'Active' && (
          <>
            <span class="phase-bar__label">Active</span>
            <span class="phase-bar__dot">·</span>
            <span class="phase-bar__detail">
              {contractHours
                ? `${monthlyHours.toFixed(1)} / ${contractHours}h this month`
                : `${monthlyHours.toFixed(1)}h this month`}
            </span>
            {lead.contractSignedAt
              ? <><span class="phase-bar__dot">·</span><span class="phase-bar__signed">✓ Contract signed</span></>
              : <><span class="phase-bar__dot">·</span><span class="phase-bar__detail phase-bar__detail--warn">Contract not signed</span></>
            }
          </>
        )}
        {isClosed && (
          <>
            <span class="phase-bar__label">{lead.stage}</span>
            <span class="phase-bar__dot">·</span>
            <span class="phase-bar__detail">{totalHours.toFixed(1)}h total logged</span>
          </>
        )}
      </div>

      <!-- Next Action: always shown, stage-aware CTA -->
      <section class="card card--next-action">
        <div class="card__body next-action-body">
          {lead.stage === 'Lead' && (
            <>
              <span class="next-action__text">Reach out to schedule an intro call.</span>
              <button class="btn-sm next-action-cta" id="btn-na-followup">Send Follow-up</button>
            </>
          )}
          {lead.stage === 'Call Scheduled' && (
            <>
              <span class="next-action__text">
                {lead.nextMeeting ? `Prepare for your call on ${lead.nextMeeting}.` : 'Prepare for your upcoming call.'}
              </span>
              <button class="btn-sm next-action-cta" id="btn-na-guide">View Discovery Guide</button>
            </>
          )}
          {isProposal && (
            <>
              <span class="next-action__text">
                {daysSinceProposal === 0 ? 'Proposal sent today.' : `Proposal sent ${daysSinceProposal}d ago — follow up.`}
              </span>
              <button class="btn-sm next-action-cta" id="btn-na-followup">Send Follow-up</button>
            </>
          )}
          {isActive && (
            <>
              <span class="next-action__text">
                {deliverablesInProgress > 0
                  ? `${deliverablesInProgress} deliverable${deliverablesInProgress === 1 ? '' : 's'} in progress · `
                  : ''}
                {contractHours
                  ? `${monthlyHours.toFixed(1)} / ${contractHours}h logged this month.`
                  : `${monthlyHours.toFixed(1)}h logged this month.`}
              </span>
              <button class="btn-sm next-action-cta" id="btn-na-logtime">Log Time</button>
            </>
          )}
          {isClosed && (
            <span class="next-action__text">Reconnect by {reconnectDate}.</span>
          )}
        </div>
      </section>

      <!-- To-Dos: always shown, all stages -->
      <section class="card" id="todos-card">
        <div class="card__header">
          <h2>To-Dos</h2>
          <span id="todos-status" class="save-status"></span>
        </div>
        <div class="card__body">
          <form id="todo-form" class="todo-add-form">
            <div class="todo-add-row">
              <input type="text" id="todo-input" placeholder="Add a task..." required class="todo-input" />
              <button type="submit" class="btn-save">Add</button>
            </div>
          </form>
          <div class="todo-list" id="todo-list">
            {(lead.todos ?? []).length > 0 ? (
              (lead.todos ?? []).map((item: TodoItem) => (
                <div class="todo-item" data-item-id={item.id}>
                  <input type="checkbox" class="todo-checkbox" data-item-id={item.id} checked={item.done} />
                  <span class:list={['todo-text', { 'todo-text--done': item.done }]}>{item.text}</span>
                  <button class="todo-delete" data-item-id={item.id} aria-label="Delete">&times;</button>
                </div>
              ))
            ) : (
              <p class="empty" id="todo-empty">No tasks yet.</p>
            )}
          </div>
        </div>
      </section>

      <!-- Call Scheduled: Meeting countdown (primary card for this stage) -->
      {lead.stage === 'Call Scheduled' && (
        <section class="card card--countdown" id="countdown-card">
          <div class="card__header">
            <h2>Next Meeting</h2>
            {lead.calBookingUid && (
              <a href={`https://app.cal.com/booking/${lead.calBookingUid}`} target="_blank" rel="noopener" class="card-action-link">View booking ↗</a>
            )}
          </div>
          <div class="card__body">
            {lead.nextMeeting ? (
              <>
                <div class="countdown-content">
                  <div class="countdown-time" id="countdown-display" data-meeting-iso={lead.nextMeetingISO ?? ''}>
                    {countdownLabel}
                  </div>
                  <div class="countdown-meeting-str">{lead.nextMeeting}</div>
                </div>
                {lead.meetingType && <div class="countdown-type">{lead.meetingType}</div>}
                <div class="countdown-actions">
                  {lead.calBookingUid && (
                    <button class="btn-sm btn-sm--danger" id="btn-cancel-call">Cancel Call</button>
                  )}
                </div>
                <div id="cancel-call-status" class="save-status"></div>
              </>
            ) : (
              <p class="empty">No meeting time set yet — add one in the sidebar.</p>
            )}
          </div>
        </section>
      )}

      <!-- Proposal Sent: summary card (primary card for this stage) -->
      {isProposal && (
        <section class="card proposal-summary-card">
          <div class="card__header">
            <h2>Proposal</h2>
            <a href={`/dashboard/${lead.id}/proposal`} class="card-action-link">Edit &amp; Resend ↗</a>
          </div>
          <div class="card__body proposal-summary-body">
            <div class="proposal-summary-row">
              <div class="proposal-summary-service">
                {serviceConfig ? serviceConfig.label : (lead.serviceInterest?.replace(/\s*\(\$[\d,]+(?:\/\w+)?\)/g, '') ?? 'Service')}
              </div>
              <div class="proposal-summary-price">
                {serviceConfig ? `$${(serviceConfig.priceCents / 100).toLocaleString()}${serviceConfig.isRecurring ? '/mo' : ''}` : ''}
              </div>
            </div>
            <div class="proposal-summary-meta">
              <span class="proposal-summary-since">
                {daysSinceProposal === 0 ? 'Sent today' : `Sent ${daysSinceProposal}d ago`}
              </span>
              {latestInvoiceStatus && (
                <span class={`proposal-inv-status proposal-inv-status--${latestInvoiceStatus}`}>
                  Invoice: {latestInvoiceStatus}{latestInvoiceAmount ? ` ${latestInvoiceAmount}` : ''}
                </span>
              )}
              {!latestInvoiceStatus && (
                <span class="proposal-inv-status proposal-inv-status--none">No invoice yet</span>
              )}
            </div>
            <div class="proposal-summary-actions">
              <button class="btn-sm" id="btn-followup-summary">Send Follow-up</button>
            </div>
          </div>
        </section>
      )}

      <!-- Closed: Wrap-up card (primary card for this stage) -->
      {isClosed && (
        <section class="card">
          <div class="card__header"><h2>Wrap-up</h2></div>
          <div class="card__body">
            <div class="wrap-stats">
              {serviceConfig && (
                <div class="wrap-stat">
                  <div class="wrap-stat__value">{serviceConfig.label}</div>
                  <div class="wrap-stat__label">Service delivered</div>
                </div>
              )}
              <div class="wrap-stat">
                <div class="wrap-stat__value">{monthsAsClient}mo</div>
                <div class="wrap-stat__label">As a client</div>
              </div>
              {totalHours > 0 && (
                <div class="wrap-stat">
                  <div class="wrap-stat__value">{totalHours.toFixed(1)}h</div>
                  <div class="wrap-stat__label">Hours logged</div>
                </div>
              )}
              {totalPaid > 0 && (
                <div class="wrap-stat">
                  <div class="wrap-stat__value">${Math.round(totalPaid).toLocaleString()}</div>
                  <div class="wrap-stat__label">Total paid</div>
                </div>
              )}
            </div>
            {lead.contractSignedAt && (
              <div class="wrap-row">
                <span class="wrap-row__label">Contract signed</span>
                <span class="wrap-row__value">{new Date(lead.contractSignedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              </div>
            )}
            <div class="wrap-row wrap-row--reconnect">
              <span class="wrap-row__label">Reconnect by</span>
              <span class="wrap-row__value wrap-row__value--accent">{reconnectDate}</span>
            </div>
          </div>
        </section>
      )}

      <!-- Closed: Proposal preview (collapsible reference) -->
      {isClosed && lead.proposalHtml && (
        <section class="card">
          <button class="card__toggle" id="closed-proposal-toggle" aria-expanded="false">
            <span class="card__toggle-label">Proposal Sent</span>
            <span class="card__toggle-arrow">▸</span>
          </button>
          <div class="card__body" id="closed-proposal-body" hidden>
            {lead.proposalSubject && <p class="proposal-meta-subject" style="margin-bottom: var(--space-4)">{lead.proposalSubject}</p>}
            <div class="proposal-preview" set:html={lead.proposalHtml} />
          </div>
        </section>
      )}

      <!-- Proposal Sent: show the sent proposal -->
      {isProposal && lead.proposalHtml && (
        <section class="card">
          <div class="card__header">
            <div>
              <h2>Proposal Sent</h2>
              {lead.proposalSubject && <p class="proposal-meta-subject">{lead.proposalSubject}</p>}
            </div>
            <a href={`/dashboard/${lead.id}/proposal`} class="card-action-link">Edit &amp; Resend ↗</a>
          </div>
          <div class="card__body">
            <div class="proposal-preview" set:html={lead.proposalHtml} />
          </div>
        </section>
      )}

      <!-- Intake Form: Lead stage only in main column -->
      {lead.stage === 'Lead' && (
      <section class="card">
        <div class="card__header">
          <h2>Intake Form</h2>
          <button class="card-action-link intake-edit-btn" id="intake-edit-btn" type="button">Edit</button>
        </div>
        <div class="card__body intake-grid" id="intake-body">
            {[
              ['Store URL', lead.storeUrl],
              ['Store Status', lead.storeStatus],
              ['Launch Date', lead.launchDate],
              ['Visual Designer', lead.hasVisualDesigner],
              ['Interested In', lead.serviceInterest],
              ['Availability', lead.availability],
              ['Timezone', lead.timezone],
              ['Referral', lead.referral],
              ['Next Meeting', lead.nextMeeting],
            ].map(([label, value]) => value ? (
              <div class="intake-row">
                <span class="intake-label">{label}</span>
                <span class="intake-value">{value}</span>
              </div>
            ) : null)}
            {lead.challenge && (
              <div class="intake-row intake-row--full">
                <span class="intake-label">Their Challenge</span>
                <span class="intake-value intake-value--long">{lead.challenge}</span>
              </div>
            )}
            {lead.additionalNotes && (
              <div class="intake-row intake-row--full">
                <span class="intake-label">Their Notes</span>
                <span class="intake-value intake-value--long">{lead.additionalNotes}</span>
              </div>
            )}
          </div>

          <!-- Intake edit form (hidden until Edit is clicked) -->
          <div class="card__body intake-edit-form" id="intake-edit-form" hidden>
            <div class="intake-edit-row">
              <label class="intake-edit-label" for="ie-store-url">Store URL</label>
              <input class="intake-edit-input" id="ie-store-url" type="url" value={lead.storeUrl ?? ''} />
            </div>
            <div class="intake-edit-row">
              <label class="intake-edit-label" for="ie-store-status">Store Status</label>
              <select class="intake-edit-input" id="ie-store-status">
                {['Not started yet', 'In progress, not live', 'Live and selling'].map(s => (
                  <option value={s} selected={s === lead.storeStatus}>{s}</option>
                ))}
              </select>
            </div>
            <div class="intake-edit-row">
              <label class="intake-edit-label" for="ie-service">Interested In</label>
              <select class="intake-edit-input" id="ie-service">
                {['Clarity Session ($500)', 'Insider Retainer ($3,500/mo)', 'Store Launch Sprint ($2,500)', 'Not sure yet'].map(s => (
                  <option value={s} selected={s === lead.serviceInterest || lead.serviceInterest?.startsWith(s.split(' (')[0])}>{s}</option>
                ))}
              </select>
            </div>
            <div class="intake-edit-row">
              <label class="intake-edit-label" for="ie-referral">Referral</label>
              <input class="intake-edit-input" id="ie-referral" type="text" value={lead.referral ?? ''} />
            </div>
            <div class="intake-edit-row">
              <label class="intake-edit-label" for="ie-timezone">Timezone</label>
              <input class="intake-edit-input" id="ie-timezone" type="text" value={lead.timezone ?? ''} />
            </div>
            <div class="intake-edit-row">
              <label class="intake-edit-label" for="ie-launch-date">Launch Date</label>
              <input class="intake-edit-input" id="ie-launch-date" type="text" value={lead.launchDate ?? ''} />
            </div>
            <div class="intake-edit-row intake-edit-row--full">
              <label class="intake-edit-label" for="ie-challenge">Their Challenge</label>
              <textarea class="intake-edit-input intake-edit-textarea" id="ie-challenge" rows="4">{lead.challenge ?? ''}</textarea>
            </div>
            <div class="intake-edit-row intake-edit-row--full">
              <label class="intake-edit-label" for="ie-notes">Their Notes</label>
              <textarea class="intake-edit-input intake-edit-textarea" id="ie-notes" rows="3">{lead.additionalNotes ?? ''}</textarea>
            </div>
            <div class="intake-edit-actions">
              <button class="btn-primary" id="intake-save-btn" type="button">Save</button>
              <button class="card-action-link" id="intake-cancel-btn" type="button">Cancel</button>
              <span class="save-status" id="intake-save-status"></span>
            </div>
          </div>
        </section>
      )}

      <!-- Discovery Call Guide: only pre-call stages -->
      {isPreCall && (
        <section class="card" id="call-guide-card">
          <button class="card__toggle" id="guide-toggle" aria-expanded={lead.stage === 'Call Scheduled' ? 'true' : 'false'}>
            <span class="card__toggle-label">
              <span class="guide-icon">📋</span> Discovery Call Guide
            </span>
            <span class="card__toggle-arrow">▸</span>
          </button>
          <div class="card__body guide-body" id="guide-body" hidden={lead.stage !== 'Call Scheduled' || undefined}>
            <div class="guide-section">
              <h3>Opening</h3>
              <blockquote>"Thanks for making time. This is a no-pitch call — I just want to understand what you're building and whether I can help. I'll take some notes as we go. Sound good?"</blockquote>
            </div>
            <div class="guide-section">
              <h3>Section 1 — Their Store <span class="guide-time">8 min</span></h3>
              <ul>
                <li>Is the store live, or are you still building it?</li>
                <li>What do you sell? Who's the customer?</li>
                <li>How long have you been on Shopify?</li>
              </ul>
              <p class="guide-if"><strong>If live:</strong> Getting traffic? Sales? AOV? Apps running?</p>
              <p class="guide-if"><strong>If not live:</strong> What's blocking the launch? Theme picked? Products ready? Deadline?</p>
            </div>
            <div class="guide-section">
              <h3>Section 2 — The Real Problem <span class="guide-time">8 min</span></h3>
              <ul>
                <li><strong>What's the #1 thing keeping you up at night about the store?</strong> <em>(Let them talk. Don't interrupt.)</em></li>
                <li>How long has that been the case?</li>
                <li>What have you tried so far?</li>
                <li>What happens if you don't solve this in the next 90 days?</li>
                <li>What does success look like in 6 months?</li>
                <li>Who else is involved in the store?</li>
              </ul>
            </div>
            <div class="guide-section">
              <h3>Section 3 — Fit Check <span class="guide-time">5 min</span></h3>
              <ul>
                <li>Worked with a Shopify consultant or agency before?</li>
                <li>What's your rough monthly budget for getting help?</li>
              </ul>
              <div class="budget-signals">
                <div class="signal">"Can't afford an agency" → <strong>Clarity Session $500</strong></div>
                <div class="signal">"Want ongoing support" → <strong>Insider Retainer $3,500/mo</strong></div>
                <div class="signal">"Need to launch fast" → <strong>Store Launch Sprint $2,500</strong></div>
                <div class="signal">"Just need focus" → <strong>Clarity Session $500</strong></div>
              </div>
            </div>
            <div class="guide-section">
              <h3>Section 4 — Your Background <span class="guide-time">3 min</span></h3>
              <blockquote>"I spent five years as Head of Design at Shopify, leading the teams that built Shopify Email, Inbox, Forms, and the Analytics and Customer sections of Admin. I know the platform from the inside."</blockquote>
            </div>
            <div class="guide-section">
              <h3>Closing <span class="guide-time">4 min</span></h3>
              <blockquote>"So it sounds like the main thing you're working on is [X], and the goal is [Y]. Is that right?"</blockquote>
              <blockquote>"Based on what you've told me, I think [SERVICE] makes the most sense. I'll send you a short proposal this afternoon — just what's included, what it costs, and how to get started."</blockquote>
            </div>
            <div class="guide-section guide-section--tree">
              <h3>Decision Tree</h3>
              <div class="decision-tree">
                <div class="tree-branch">Store not live → <strong>Store Launch Sprint $2,500</strong></div>
                <div class="tree-branch">Live, needs audit → <strong>Clarity Session $500</strong> → offer Retainer after</div>
                <div class="tree-branch">Live, wants ongoing → <strong>Insider Retainer $3,500/mo</strong></div>
                <div class="tree-branch">Unsure / testing → <strong>Clarity Session $500</strong> (lowest barrier)</div>
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- Work Log: unified notes / time / deliverables — primary card for non-Lead stages -->
      <section class="card" id="work-log">

        <!-- Tab bar -->
        <div class="work-tabs">
          <button class="work-tab work-tab--active" data-tab="note" id="work-tab-note">Note</button>
          {isActive && (
            <button class="work-tab" data-tab="time" id="work-tab-time">
              Time{monthlyHours > 0 ? ` · ${monthlyHours.toFixed(1)}h` : ''}
            </button>
          )}
          {isActive && (
            <button class="work-tab" data-tab="deliverable" id="work-tab-deliverable">
              Deliverables{deliverablesInProgress > 0 ? ` · ${deliverablesInProgress}` : ''}
            </button>
          )}
          <span id="activity-status" class="save-status work-status"></span>
        </div>

        <!-- Note panel -->
        <div class="work-panel" id="work-panel-note">
          <form id="activity-form" class="activity-form-container">
            <div class="md-editor activity-editor">
              <div class="md-toolbar md-toolbar--compact">
                <select id="activity-type" class="work-type-select md-select" style="margin-right: var(--space-2); border: none; background: transparent; cursor: pointer; outline: none;">
                  <option value="Note">Note</option>
                  <option value="Call">Call</option>
                  <option value="Email">Email</option>
                </select>
                <button type="button" class="md-btn md-btn--bold" data-action="bold" title="Bold">B</button>
                <button type="button" class="md-btn md-btn--italic" data-action="italic" title="Italic">I</button>
                <button type="button" class="md-btn" data-action="link" title="Link">⌘K</button>
                <span class="md-toolbar__sep"></span>
                <button type="button" class="md-btn md-btn--mono" data-action="code" title="Code">`</button>
                <button type="button" class="md-btn" data-action="heading" title="Heading">H2</button>
                <button type="button" class="md-btn" data-action="list" title="List">—</button>
              </div>
              <textarea id="activity-text" rows="4" placeholder="What happened, decisions made, notes from a call..." class="work-textarea md-textarea" style="border-top-left-radius: 0; border-top-right-radius: 0; border-top: 0;"></textarea>
            </div>
            <div class="work-panel-footer">
              <span id="activity-status" class="save-status work-status" style="margin-right: var(--space-4);"></span>
              <button type="submit" class="btn-save" style="margin-left: auto;">Save</button>
            </div>
          </form>
        </div>

        <!-- Time panel (Active only) -->
        {isActive && (
          <div class="work-panel" id="work-panel-time" hidden>
            <form id="time-form">
              <div class="work-time-row">
                <div class="form-row">
                  <label for="time-date">Date</label>
                  <input type="date" id="time-date" name="date" required value={thisMonthPrefix + '-' + String(now.getDate()).padStart(2, '0')} />
                </div>
                <div class="form-row">
                  <label for="time-hours">Hours</label>
                  <select id="time-hours" name="hours">
                    {[
                      [0.25,'0.25'],[0.5,'0.5'],[0.75,'0.75'],
                      [1,'1'],[1.25,'1.25'],[1.5,'1.5'],[1.75,'1.75'],
                      [2,'2'],[2.5,'2.5'],[3,'3'],[3.5,'3.5'],
                      [4,'4'],[4.5,'4.5'],[5,'5'],[6,'6'],[7,'7'],[8,'8'],
                    ].map(([v,l]) => <option value={v}>{l}h</option>)}
                  </select>
                </div>
                <div class="form-row work-time-desc-col">
                  <label for="time-desc">Description</label>
                  <input type="text" id="time-desc" name="description" placeholder="What you worked on..." list="time-desc-list" autocomplete="off" />
                  <datalist id="time-desc-list"></datalist>
                </div>
              </div>
              <div class="work-panel-footer">
                <span id="time-month-label" class="work-time-summary">
                  {contractHours ? `${monthlyHours.toFixed(1)} / ${contractHours}h this month` : `${monthlyHours.toFixed(1)}h this month`}
                </span>
                <div id="time-feedback" class="form-feedback"></div>
                <button type="submit" id="time-submit" class="btn-save">Log Time</button>
              </div>
            </form>
          </div>
        )}

        <!-- Deliverable panel (Active only) -->
        {isActive && (
          <div class="work-panel" id="work-panel-deliverable" hidden>
            <form id="deliverable-form" class="deliverable-add-form">
              <div class="deliverable-add-row">
                <input type="text" id="deliverable-title" placeholder="Add a deliverable..." required class="deliverable-input" />
                <button type="submit" class="btn-save">Add</button>
              </div>
              <span id="deliverables-status" class="save-status" style="margin-top:var(--space-2);display:block"></span>
            </form>
            <div class="deliverable-list" id="deliverable-list">
              {(lead.deliverables ?? []).length > 0 ? (
                (lead.deliverables ?? []).map(item => (
                  <div class="deliverable-item" data-item-id={item.id} data-status={item.status}>
                    <button class={`deliverable-status-btn deliverable-status-btn--${item.status}`} data-item-id={item.id} aria-label="Toggle status">
                      {item.status === 'done' ? '✓' : item.status === 'in-progress' ? '◑' : '○'}
                    </button>
                    <span class={`deliverable-title-text${item.status === 'done' ? ' deliverable-title-text--done' : ''}`}>{item.title}</span>
                    <button class="deliverable-delete-btn" data-item-id={item.id} aria-label="Delete">&times;</button>
                  </div>
                ))
              ) : (
                <p class="empty" id="deliverable-empty">No deliverables yet.</p>
              )}
            </div>
          </div>
        )}

        <!-- Unified feed: activity entries + time entries, merged by date -->
        <div class="work-feed" id="work-feed">
          {feedItems.length > 0 ? feedItems.map(item => (
            item.kind === 'activity' ? (
              <div class="feed-entry feed-entry--activity" data-entry-id={item.data.id}>
                <div class="feed-entry__meta">
                  <span class={`activity-badge activity-badge--${item.data.type.toLowerCase()}`}>{item.data.type}</span>
                  <span class="feed-entry__date">{new Date(item.data.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                  <button class="feed-entry__delete activity-entry__delete" data-entry-id={item.data.id} aria-label="Delete">&times;</button>
                </div>
                <div class="feed-entry__body md-content" set:html={marked.parse(item.data.text)} />
              </div>
            ) : (
              <div class="feed-entry feed-entry--time" data-entry-id={item.data.id}>
                <div class="feed-entry__meta">
                  <span class="time-badge">{item.data.hours}h</span>
                  <span class="feed-entry__date">{item.data.date}</span>
                  <button class="feed-entry__delete time-entry__delete" data-entry-id={item.data.id} aria-label="Delete">&times;</button>
                </div>
                {item.data.description && <div class="feed-entry__body">{item.data.description}</div>}
              </div>
            )
          )) : (
            <p class="empty" id="work-feed-empty">Nothing logged yet.</p>
          )}
        </div>

      </section>

    </div>

    <!-- ── Sidebar ── -->
    <aside class="lead-sidebar">

      <!-- Next Meeting: all non-closed stages -->
      {!isClosed && (
        <section class="card">
          <div class="card__header"><h2>Next Meeting</h2></div>
          <div class="card__body">
            <div class="form-row">
              <label>Date &amp; time</label>
              <div class="stripe-id-row">
                <input type="text" id="next-meeting-input" value={lead.nextMeeting ?? ''} placeholder="e.g. Apr 10, 12:30 CT" data-lead-id={lead.id} />
                <button id="next-meeting-save" class="btn-save">Save</button>
              </div>
              <span id="next-meeting-status" class="save-status"></span>
            </div>
          </div>
        </section>
      )}

      <!-- Stage Checklist -->
      {checklist.length > 0 && (
        <section class="card">
          <div class="card__header">
            <h2>Checklist</h2>
            <span id="checklist-status" class="save-status"></span>
          </div>
          <div class="card__body">
            <div class="checklist" id="stage-checklist">
              {checklist.map(item => (
                <label class="checklist-item">
                  <input type="checkbox" class="check-input" data-item={item}
                    checked={completedChecks.includes(item)} />
                  <span class:list={['check-label', { 'check-label--done': completedChecks.includes(item) }]}>
                    {item}
                  </span>
                </label>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- Contract: Active stage only -->
      {isActive && (
        <section class="card">
          <div class="card__header"><h2>Contract</h2></div>
          <div class="card__body">
            {lead.contractSignedAt ? (
              <div class="contract-signed-state">
                <span class="contract-signed-check">✓ Signed</span>
                <span class="contract-signed-date">
                  {new Date(lead.contractSignedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </span>
              </div>
            ) : (
              <button id="contract-sign-btn" class="action-btn action-btn--accent" style="width:100%">
                Mark as Signed
              </button>
            )}
            <span id="contract-status" class="save-status"></span>
          </div>
        </section>
      )}

      <!-- Actions: stage-specific -->
      {!isClosed && (
        <section class="card">
          <div class="card__header"><h2>Actions</h2></div>
          <div class="card__body">
            <div class="sidebar-actions">
              {isPreCall && (
                <a href={`/dashboard/${lead.id}/proposal`} class="action-btn action-btn--accent action-btn--link">Send Proposal ↗</a>
              )}
              {isProposal && (
                <a href={`/dashboard/${lead.id}/proposal`} class="action-btn action-btn--link">Edit &amp; Resend Proposal ↗</a>
              )}
              {isActive && (
                <button class="action-btn action-btn--accent" id="btn-invoice">Send Invoice</button>
              )}
              {!isActive && (
                <button class="action-btn" id="btn-followup">Send Follow-up</button>
              )}
            </div>
          </div>

          <!-- Invoice form panel (Active only) -->
          {isActive && (
            <div class="action-panel" id="panel-invoice" hidden
              data-service={serviceConfig?.label ?? ''}
              data-amount={serviceConfig?.invoiceAmountStr ?? ''}>
              <form id="invoice-form">
                <div class="form-row">
                  <label>Service</label>
                  <select name="service" id="inv-service">
                    <option value="Clarity Session">Clarity Session</option>
                    <option value="Store Launch Sprint">Store Launch Sprint</option>
                    <option value="Insider Retainer">Insider Retainer</option>
                    <option value="Custom">Custom</option>
                  </select>
                </div>
                <div id="inv-line-items">
                  <div class="inv-line-item" data-idx="0">
                    <div class="form-row">
                      <label>Description</label>
                      <input type="text" class="inv-item-desc" placeholder="e.g. Monthly retainer — May" />
                    </div>
                    <div class="form-row">
                      <label>Amount (USD)</label>
                      <input type="number" class="inv-item-amount" min="1" step="0.01" placeholder="500" />
                    </div>
                  </div>
                </div>
                <button type="button" id="inv-add-line" class="btn-sm" style="margin-bottom: var(--space-3)">+ Add line item</button>
                <div id="invoice-preview" class="invoice-preview" hidden></div>
                <div id="invoice-feedback" class="form-feedback"></div>
                <div class="panel-actions">
                  <button type="button" class="btn-cancel" data-panel="invoice">Cancel</button>
                  <button type="button" id="btn-preview-invoice" class="btn-send">Preview</button>
                  <button type="submit" id="btn-confirm-invoice" class="btn-send" hidden>Confirm &amp; Send</button>
                </div>
              </form>
            </div>
          )}

          <!-- Last activity line -->
          {lastActivity && (
            <div class="last-activity-line">
              <span class={`last-activity-badge last-activity-badge--${lastActivity.type.toLowerCase()}`}>{lastActivity.type}</span>
              <span class="last-activity-when">{lastActivityDaysAgo === 0 ? 'today' : `${lastActivityDaysAgo}d ago`}</span>
            </div>
          )}

          <!-- Follow-up form panel (non-Active) -->
          {!isActive && (
            <div class="action-panel" id="panel-followup" hidden>
              <form id="followup-form">
                <div class="form-row">
                  <label>To</label>
                  <input type="email" name="to" value={lead.email} readonly />
                </div>
                <div class="form-row">
                  <label>Subject</label>
                  <input type="text" name="subject" id="fu-subject" value="Quick note from Travis" />
                </div>
                <div class="form-row">
                  <label>Body</label>
                  <textarea name="body" id="fu-body" rows="8"></textarea>
                </div>
                <div id="followup-feedback" class="form-feedback"></div>
                <div class="panel-actions">
                  <button type="button" class="btn-cancel" data-panel="followup">Cancel</button>
                  <button type="submit" class="btn-send">Send Email</button>
                </div>
              </form>
            </div>
          )}
        </section>
      )}

      <!-- Retainer billing status (Active retainer clients) -->
      {isActive && isRetainer && (
        <section class="card">
          <div class="card__header"><h2>This Month</h2><span class="card__sub">{currentMonthLabel}</span></div>
          <div class="card__body">
            {thisMonthInvoice ? (
              <div class="retainer-billing-row">
                <div class="retainer-billing-info">
                  <span class={`retainer-billing-status retainer-billing-status--${thisMonthInvoice.status}`}>
                    {thisMonthInvoice.status === 'paid' ? 'Paid' : thisMonthInvoice.status === 'open' ? 'Open — awaiting payment' : thisMonthInvoice.status}
                  </span>
                  <span class="retainer-billing-amount">${((thisMonthInvoice.amount_due ?? 0) / 100).toFixed(2)}</span>
                </div>
                {thisMonthInvoice.hosted_invoice_url && (
                  <a href={thisMonthInvoice.hosted_invoice_url} target="_blank" rel="noopener" class="btn-sm">View Invoice</a>
                )}
              </div>
            ) : (
              <div class="retainer-billing-row retainer-billing-row--unsent">
                <span class="retainer-billing-status retainer-billing-status--not_sent">Not sent yet</span>
                <button class="btn-sm" id="btn-send-retainer-invoice">Send Now</button>
              </div>
            )}
          </div>
        </section>
      )}

      <!-- Invoices: proposal sent and beyond -->
      {!isPreCall && (
        <section class="card">
          <div class="card__header"><h2>Invoices</h2></div>
          <div class="card__body">
            {invoices.length === 0 ? (
              <p class="empty">No invoices yet</p>
            ) : (
              <div class="invoice-list">
                {invoices.map((inv: any, idx: number) => {
                  const isThisMonth = inv.created >= billingMonthStart;
                  const lineDesc = inv.lines?.data?.[0]?.description ?? null;
                  return (
                    <div class="invoice-row">
                      <div class="invoice-row__info">
                        <div class="invoice-row__top">
                          {inv.hosted_invoice_url ? (
                            <a href={inv.hosted_invoice_url} target="_blank" rel="noopener" class="invoice-num">
                              {inv.number ?? inv.id.slice(-8)}
                            </a>
                          ) : (
                            <span class="invoice-num">{inv.number ?? inv.id.slice(-8)}</span>
                          )}
                          {idx === 0 && isThisMonth && (
                            <span class="invoice-this-month">This month</span>
                          )}
                        </div>
                        {lineDesc && <div class="invoice-line-desc">{lineDesc}</div>}
                        <span class="invoice-date">{new Date(inv.created * 1000).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                      </div>
                      <div class="invoice-row__meta">
                        <span class={`inv-status inv-status--${inv.status}`}>{inv.status}</span>
                        <span class="invoice-amount">${((inv.amount_due ?? 0) / 100).toFixed(2)}</span>
                      </div>
                    </div>
                  );
                })}
              </div>
            )}
            {totalPaid > 0 && (
              <div class="invoice-total-paid">
                <span>Total paid</span>
                <span class="invoice-total-paid__value">${Math.round(totalPaid).toLocaleString()}</span>
              </div>
            )}
          </div>
        </section>
      )}

      <!-- Stripe Customer ID: proposal sent and beyond -->
      {!isPreCall && (
        <section class="card">
          <div class="card__header"><h2>Stripe</h2></div>
          <div class="card__body">
            <div class="form-row">
              <label>Customer ID</label>
              <div class="stripe-id-row">
                <input type="text" id="stripe-customer-id" value={lead.stripeCustomerId} placeholder="cus_..." data-lead-id={lead.id} />
                <button id="stripe-id-save" class="btn-save">Save</button>
              </div>
              <span id="stripe-id-status" class="save-status"></span>
            </div>
          </div>
        </section>
      )}

      <!-- Reminders toggle -->
      {(lead.stage === 'Lead' || lead.stage === 'Proposal Sent') && (
        <section class="card">
          <div class="card__header"><h2>Reminders</h2></div>
          <div class="card__body">
            <div class="reminder-status">
              {lead.unsubscribed ? (
                <span class="reminder-badge reminder-badge--off">Client unsubscribed</span>
              ) : lead.remindersDisabled ? (
                <span class="reminder-badge reminder-badge--off">Reminders off</span>
              ) : (
                <span class="reminder-badge reminder-badge--on">Reminders on</span>
              )}
              {!lead.unsubscribed && (
                <div class="reminder-detail">
                  {lead.stage === 'Lead' && (
                    <span>{lead.remindersSentSchedule ?? 0}/4 schedule reminders sent</span>
                  )}
                  {lead.stage === 'Proposal Sent' && (
                    <span>{lead.remindersSentProposal ?? 0}/4 proposal reminders sent</span>
                  )}
                </div>
              )}
            </div>
            {!lead.unsubscribed && (
              <button
                id="reminder-toggle-btn"
                class="btn-save"
                data-disabled={String(!!lead.remindersDisabled)}
                style="margin-top: var(--space-4); width: 100%"
              >
                {lead.remindersDisabled ? 'Turn reminders on' : 'Turn reminders off'}
              </button>
            )}
            <span id="reminder-toggle-status" class="save-status" style="margin-top: var(--space-2); display:block"></span>
          </div>
        </section>
      )}

      <!-- Client Info: non-Lead stages — compact sidebar collapsible -->
      {lead.stage !== 'Lead' && (
        <section class="card">
          <button class="card__toggle" id="client-info-toggle" aria-expanded="false">
            <span class="card__toggle-label">Client Info</span>
            <span class="card__toggle-arrow">▸</span>
          </button>
          <div class="card__body" id="client-info-body" hidden>
            <div id="client-info-view">
              {lead.storeUrl && (
                <div class="ci-row">
                  <span class="ci-label">Store</span>
                  <a href={lead.storeUrl} target="_blank" rel="noopener" class="ci-value ci-value--link">{lead.storeUrl.replace(/^https?:\/\//, '')}</a>
                </div>
              )}
              {lead.serviceInterest && (
                <div class="ci-row">
                  <span class="ci-label">Service</span>
                  <span class="ci-value">{lead.serviceInterest.replace(/\s*\(\$[\d,]+(?:\/\w+)?\)/g, '')}</span>
                </div>
              )}
              {lead.referral && (
                <div class="ci-row">
                  <span class="ci-label">Referral</span>
                  <span class="ci-value">{lead.referral}</span>
                </div>
              )}
              {lead.timezone && (
                <div class="ci-row">
                  <span class="ci-label">Timezone</span>
                  <span class="ci-value">{lead.timezone}</span>
                </div>
              )}
              {lead.challenge && (
                <div class="ci-row ci-row--full">
                  <span class="ci-label">Challenge</span>
                  <span class="ci-value ci-value--wrap">{lead.challenge}</span>
                </div>
              )}
              {lead.additionalNotes && (
                <div class="ci-row ci-row--full">
                  <span class="ci-label">Their Notes</span>
                  <span class="ci-value ci-value--wrap">{lead.additionalNotes}</span>
                </div>
              )}
              <button type="button" class="card-action-link" id="intake-edit-btn" style="margin-top:var(--space-3)">Edit</button>
            </div>

            <!-- Reuse intake edit form (same IDs, now in sidebar for non-Lead) -->
            <div class="intake-edit-form" id="intake-edit-form" hidden>
              <div class="intake-edit-row">
                <label class="intake-edit-label" for="ie-store-url">Store URL</label>
                <input class="intake-edit-input" id="ie-store-url" type="url" value={lead.storeUrl ?? ''} />
              </div>
              <div class="intake-edit-row">
                <label class="intake-edit-label" for="ie-store-status">Store Status</label>
                <select class="intake-edit-input" id="ie-store-status">
                  {['Not started yet', 'In progress, not live', 'Live and selling'].map(s => (
                    <option value={s} selected={s === lead.storeStatus}>{s}</option>
                  ))}
                </select>
              </div>
              <div class="intake-edit-row">
                <label class="intake-edit-label" for="ie-service">Interested In</label>
                <select class="intake-edit-input" id="ie-service">
                  {['Clarity Session ($500)', 'Insider Retainer ($3,500/mo)', 'Store Launch Sprint ($2,500)', 'Not sure yet'].map(s => (
                    <option value={s} selected={s === lead.serviceInterest || lead.serviceInterest?.startsWith(s.split(' (')[0])}>{s}</option>
                  ))}
                </select>
              </div>
              <div class="intake-edit-row">
                <label class="intake-edit-label" for="ie-referral">Referral</label>
                <input class="intake-edit-input" id="ie-referral" type="text" value={lead.referral ?? ''} />
              </div>
              <div class="intake-edit-row">
                <label class="intake-edit-label" for="ie-timezone">Timezone</label>
                <input class="intake-edit-input" id="ie-timezone" type="text" value={lead.timezone ?? ''} />
              </div>
              <div class="intake-edit-row">
                <label class="intake-edit-label" for="ie-launch-date">Launch Date</label>
                <input class="intake-edit-input" id="ie-launch-date" type="text" value={lead.launchDate ?? ''} />
              </div>
              <div class="intake-edit-row intake-edit-row--full">
                <label class="intake-edit-label" for="ie-challenge">Their Challenge</label>
                <textarea class="intake-edit-input intake-edit-textarea" id="ie-challenge" rows="4">{lead.challenge ?? ''}</textarea>
              </div>
              <div class="intake-edit-row intake-edit-row--full">
                <label class="intake-edit-label" for="ie-notes">Their Notes</label>
                <textarea class="intake-edit-input intake-edit-textarea" id="ie-notes" rows="3">{lead.additionalNotes ?? ''}</textarea>
              </div>
              <div class="intake-edit-actions">
                <button class="btn-primary" id="intake-save-btn" type="button">Save</button>
                <button class="card-action-link" id="intake-cancel-btn" type="button">Cancel</button>
                <span class="save-status" id="intake-save-status"></span>
              </div>
            </div>
          </div>
        </section>
      )}

    </aside>
  </div>
  </div>
</div>
</BaseLayout>

<style>
  .lead-page {
    min-height: 100vh;
    background: var(--color-bg-alt);
  }

  /* ── Header ── */
  .lead-header {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) 0;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .lead-header__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .lead-header__left {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    min-width: 0;
  }

  .lead-header__title {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
    min-width: 0;
  }

  .lead-header__title h1 {
    font-size: var(--text-xl);
    margin: 0;
    white-space: nowrap;
  }

  .lead-email {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .lead-email:hover { color: var(--color-text-secondary); }

  .lead-store {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    opacity: 0.8;
  }

  .lead-store:hover { opacity: 1; }

  .lead-header__right {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .header-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-tertiary);
  }

  .stage-select {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    background: var(--color-bg);
    color: var(--color-text);
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: border-color 0.15s;
  }

  .stage-select:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .save-status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    min-width: 60px;
    transition: opacity 0.3s;
  }

  .save-status.saving { color: var(--color-text-tertiary); }
  .save-status.saved  { color: #38a169; }
  .save-status.error  { color: #e53e3e; }

  /* ── Body layout ── */
  .lead-body {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--space-8);
    padding: var(--space-8) 0;
    align-items: start;
  }

  @media (max-width: 960px) {
    .lead-body { grid-template-columns: 1fr; }
  }

  /* ── Cards ── */
  .card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-6);
    overflow: hidden;
  }

  .card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }

  .card__header h2 {
    font-size: var(--text-sm);
    font-weight: 600;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .card__body {
    padding: var(--space-5);
  }

  /* ── Call Guide ── */
  .card__toggle {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-4) var(--space-6);
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    transition: background 0.15s;
  }

  .card__toggle:hover { background: var(--color-bg-alt); }

  .card__toggle-label {
    font-size: var(--text-sm);
    font-weight: 600;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .card__toggle-arrow {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    transition: transform 0.2s;
  }

  .card__toggle[aria-expanded="true"] .card__toggle-arrow {
    transform: rotate(90deg);
  }

  .guide-body {
    padding: var(--space-5);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .guide-section {
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .guide-section:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .guide-section h3 {
    font-size: var(--text-xs);
    font-weight: 700;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-tertiary);
    margin: 0 0 var(--space-3);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .guide-time {
    font-weight: 400;
    color: var(--color-border-strong);
    background: var(--color-bg-alt);
    padding: 1px var(--space-2);
    border-radius: var(--radius-sm);
  }

  .guide-section ul {
    padding-left: var(--space-4);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .guide-section ul li {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.55;
  }

  .guide-section blockquote {
    margin: var(--space-3) 0 0;
    padding: var(--space-4) var(--space-6);
    border-left: 3px solid var(--color-accent);
    background: var(--color-bg-alt);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .guide-section blockquote + blockquote {
    margin-top: var(--space-3);
  }

  .guide-if {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: var(--space-3) 0 0;
    line-height: 1.5;
  }

  .budget-signals {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .signal {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .signal strong { color: var(--color-accent); }

  .decision-tree {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .tree-branch {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .tree-branch strong { color: var(--color-text); }

  /* ── Notes ── */
  .notes-textarea {
    width: 100%;
    min-height: 240px;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-sm);
    line-height: 1.65;
    resize: vertical;
    background: var(--color-bg);
    color: var(--color-text);
    box-sizing: border-box;
    transition: border-color 0.15s;
  }

  .notes-textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  /* ── Markdown editor ── */
  .md-editor {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .md-toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-bottom: none;
    border-radius: var(--radius-md) var(--radius-md) 0 0;
  }

  .md-toolbar--compact {
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
  }

  .md-btn {
    background: none;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    padding: 2px 6px;
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-secondary);
    cursor: pointer;
    line-height: 1.4;
    transition: background 0.1s, border-color 0.1s, color 0.1s;
  }

  .md-btn:hover {
    background: var(--color-bg);
    border-color: var(--color-border);
    color: var(--color-text);
  }

  .md-btn--bold { font-weight: 700; }
  .md-btn--italic { font-style: italic; }
  .md-btn--mono { font-family: var(--font-mono); }

  .md-toolbar__sep {
    flex: 1;
  }

  .md-preview-toggle {
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 2px 10px;
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-tertiary);
    cursor: pointer;
    transition: color 0.1s, border-color 0.1s;
  }

  .md-preview-toggle:hover {
    color: var(--color-text);
    border-color: var(--color-text-tertiary);
  }

  .md-editor .notes-textarea {
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }

  .md-preview {
    min-height: 240px;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    background: var(--color-bg);
    overflow-y: auto;
  }

  /* ── Markdown rendered content ── */
  .md-content {
    font-size: var(--text-sm);
    line-height: 1.65;
    color: var(--color-text);
  }

  .md-content p { margin: 0 0 var(--space-3); }
  .md-content p:last-child { margin-bottom: 0; }
  .md-content h1, .md-content h2, .md-content h3 {
    font-weight: 600;
    margin: var(--space-4) 0 var(--space-2);
    color: var(--color-text);
  }
  .md-content h1 { font-size: var(--text-base); }
  .md-content h2 { font-size: var(--text-sm); }
  .md-content h3 { font-size: var(--text-sm); color: var(--color-text-secondary); }
  .md-content h1:first-child, .md-content h2:first-child, .md-content h3:first-child { margin-top: 0; }
  .md-content ul, .md-content ol {
    margin: 0 0 var(--space-3);
    padding-left: var(--space-6);
  }
  .md-content li { margin-bottom: var(--space-1); }
  .md-content a {
    color: var(--color-accent);
    text-decoration: underline;
  }
  .md-content a:hover { opacity: 0.8; }
  .md-content code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-alt);
    padding: 1px 4px;
    border-radius: 3px;
    color: var(--color-text);
  }
  .md-content pre {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    overflow-x: auto;
    margin: 0 0 var(--space-3);
  }
  .md-content pre code {
    background: none;
    padding: 0;
  }
  .md-content blockquote {
    border-left: 3px solid var(--color-border);
    margin: 0 0 var(--space-3);
    padding: var(--space-2) var(--space-4);
    color: var(--color-text-secondary);
  }
  .md-content strong { font-weight: 600; }
  .md-content em { font-style: italic; }
  .md-content hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-4) 0;
  }

  /* ── Activity editor layout ── */
  .activity-editor {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .activity-editor .md-toolbar {
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
  }

  .activity-editor .activity-textarea {
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }

  /* ── Intake ── */
  .intake-grid {
    display: flex;
    flex-direction: column;
  }

  .intake-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--space-4);
    align-items: start;
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .intake-row:first-child { padding-top: 0; }
  .intake-row:last-child { border-bottom: none; padding-bottom: 0; }

  .intake-row--full {
    grid-template-columns: 140px 1fr;
  }

  .intake-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
    padding-top: 2px;
    line-height: 1.4;
  }

  .intake-value {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.55;
  }

  .intake-value--long {
    white-space: pre-wrap;
  }

  /* ── Intake edit form ── */
  .intake-edit-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .intake-edit-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--space-4);
    align-items: start;
  }

  .intake-edit-row--full {
    grid-template-columns: 140px 1fr;
  }

  .intake-edit-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
    padding-top: 8px;
  }

  .intake-edit-input {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-3);
    width: 100%;
  }

  .intake-edit-input:focus {
    outline: none;
    border-color: var(--color-text);
  }

  .intake-edit-textarea {
    resize: vertical;
    min-height: 80px;
    line-height: 1.5;
  }

  .intake-edit-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding-top: var(--space-2);
    grid-column: 1 / -1;
  }

  /* ── Sidebar ── */
  .lead-sidebar .card { margin-bottom: var(--space-4); }

  /* Action buttons */
  .sidebar-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .action-btn {
    width: 100%;
    padding: var(--space-4) var(--space-5);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
    text-align: left;
    transition: all 0.15s;
    color: var(--color-text);
  }

  .action-btn:hover {
    background: var(--color-bg);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .action-btn--accent {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }

  .action-btn--accent:hover {
    background: var(--color-accent-hover);
    color: #fff;
    border-color: var(--color-accent-hover);
  }

  .action-btn--link {
    display: block;
    text-align: left;
    text-decoration: none;
  }

  /* Action panels */
  .action-panel {
    padding: var(--space-6);
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-alt);
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-bottom: var(--space-4);
  }

  .form-row:last-of-type { margin-bottom: 0; }

  .form-row label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
  }

  .form-row input,
  .form-row select,
  .form-row textarea {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-sm);
    background: var(--color-bg);
    color: var(--color-text);
    transition: border-color 0.15s;
    width: 100%;
    box-sizing: border-box;
  }

  .form-row input:focus,
  .form-row select:focus,
  .form-row textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .form-row input[readonly] {
    opacity: 0.5;
    cursor: default;
  }

  .form-row textarea { resize: vertical; }

  .panel-actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .btn-cancel {
    padding: var(--space-3) var(--space-4);
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.15s;
  }

  .btn-cancel:hover {
    border-color: var(--color-text-secondary);
    color: var(--color-text);
  }

  .btn-send {
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    cursor: pointer;
    transition: all 0.15s;
  }

  .btn-send:hover {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-send--accent {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-send--accent:hover { background: var(--color-accent-hover); border-color: var(--color-accent-hover); }

  .form-feedback {
    font-size: var(--text-xs);
    min-height: 1.2em;
    font-family: var(--font-mono);
    margin-top: var(--space-3);
  }

  .form-feedback.success { color: #38a169; }
  .form-feedback.error   { color: #e53e3e; }

  /* ── Invoice list ── */
  .invoice-list {
    display: flex;
    flex-direction: column;
  }

  .invoice-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .invoice-row:first-child { padding-top: 0; }
  .invoice-row:last-child { border-bottom: none; padding-bottom: 0; }

  .invoice-row__info {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .invoice-num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    font-weight: 500;
  }

  a.invoice-num:hover { text-decoration: underline; }

  .invoice-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .invoice-row__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 3px;
  }

  .inv-status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .inv-status--paid   { color: #38a169; }
  .inv-status--open   { color: #d69e2e; }
  .inv-status--draft  { color: var(--color-text-tertiary); }
  .inv-status--void   { color: #e53e3e; }

  .invoice-amount {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .invoice-row__top {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .invoice-this-month {
    font-size: var(--text-xs);
    background: #dbeafe;
    color: #1e40af;
    padding: 1px 6px;
    border-radius: var(--radius-sm);
    font-weight: 500;
  }

  .invoice-line-desc {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    line-height: 1.3;
  }

  .invoice-total-paid {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-3);
    margin-top: var(--space-2);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .invoice-total-paid__value {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  /* ── Retainer billing status card ── */
  .retainer-billing-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .retainer-billing-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .retainer-billing-status {
    font-size: var(--text-xs);
    font-weight: 600;
  }

  .retainer-billing-status--paid { color: #38a169; }
  .retainer-billing-status--open { color: #d69e2e; }
  .retainer-billing-status--not_sent { color: #e53e3e; }

  .retainer-billing-amount {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
  }

  /* ── Invoice preview box ── */
  .invoice-preview {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-3);
    background: var(--color-bg-alt);
    font-size: var(--text-sm);
    margin-bottom: var(--space-3);
  }

  /* ── Reminders ── */
  .reminder-status {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .reminder-badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    width: fit-content;
  }

  .reminder-badge--on {
    background: color-mix(in srgb, #38a169 12%, transparent);
    color: #38a169;
  }

  .reminder-badge--off {
    background: color-mix(in srgb, var(--color-text-tertiary) 12%, transparent);
    color: var(--color-text-tertiary);
  }

  .reminder-detail {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  /* ── Stripe ID row ── */
  .stripe-id-row {
    display: flex;
    gap: var(--space-2);
  }

  .stripe-id-row input { flex: 1; }

  .btn-save {
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-xs);
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    color: var(--color-text-secondary);
    transition: all 0.15s;
  }

  .btn-save:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .empty {
    color: var(--color-text-tertiary);
    font-style: italic;
    font-size: var(--text-sm);
    margin: 0;
  }

  /* ── Time tracking ── */
  .time-header-right {
    display: flex;
    align-items: center;
  }

  .time-month-total {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .time-log-form {
    margin-bottom: var(--space-4);
  }

  .time-form-row {
    display: flex;
    gap: var(--space-3);
    align-items: flex-end;
  }

  .time-form-row .form-row {
    margin-bottom: 0;
  }

  .time-form-row .form-row:first-child { flex: 0 0 130px; }
  .time-form-row .form-row:nth-child(2) { flex: 0 0 80px; }
  .time-desc-row { flex: 1 !important; }

  .time-form-actions {
    flex-shrink: 0;
    padding-bottom: 1px;
  }

  @media (max-width: 640px) {
    .time-form-row { flex-wrap: wrap; }
    .time-form-row .form-row { flex: 1 1 120px; }
  }

  .time-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-2);
  }

  .time-entry {
    display: grid;
    grid-template-columns: 100px 48px 1fr 28px;
    gap: var(--space-3);
    align-items: center;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .time-entry:last-child { border-bottom: none; }

  .time-entry__date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .time-entry__hours {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    text-align: right;
  }

  .time-entry__desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .time-entry__delete {
    background: none;
    border: none;
    color: var(--color-text-tertiary);
    cursor: pointer;
    font-size: var(--text-base);
    line-height: 1;
    padding: 2px 4px;
    border-radius: var(--radius-sm);
    transition: color 0.12s;
    text-align: center;
  }

  .time-entry__delete:hover { color: #e53e3e; }

  /* ── Phase badge ── */
  .phase-badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--phase-color);
    padding: 3px var(--space-3);
    border: 1px solid var(--phase-color);
    border-radius: var(--radius-sm);
    opacity: 0.9;
    flex-shrink: 0;
  }

  /* ── Proposal card ── */
  .proposal-meta-subject {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    margin: 4px 0 0;
  }

  .card-action-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .card-action-link:hover { text-decoration: underline; }

  .proposal-preview {
    font-size: var(--text-sm);
    line-height: 1.75;
    color: var(--color-text);
  }

  .proposal-preview h1,
  .proposal-preview h2 {
    font-size: var(--text-base);
    font-weight: 600;
    margin: var(--space-5) 0 var(--space-2);
  }

  .proposal-preview h3 {
    font-size: var(--text-xs);
    font-weight: 700;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-secondary);
    margin: var(--space-6) 0 var(--space-2);
  }

  .proposal-preview p { margin: var(--space-3) 0; }
  .proposal-preview p:first-child { margin-top: 0; }

  .proposal-preview ul,
  .proposal-preview ol {
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin: var(--space-3) 0;
  }

  .proposal-preview li { line-height: 1.6; }
  .proposal-preview strong { font-weight: 600; }

  .proposal-preview hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-6) 0;
  }

  /* ── Wrap-up card ── */
  .wrap-note {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-4);
  }

  .wrap-summary {
    margin: 0;
    padding: var(--space-4) var(--space-5);
    border-left: 3px solid var(--color-border);
    background: var(--color-bg-alt);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.65;
    white-space: pre-wrap;
  }

  /* ── Stage Checklist ── */
  .checklist {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .checklist-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    cursor: pointer;
  }

  .check-input {
    margin-top: 3px;
    flex-shrink: 0;
    accent-color: var(--color-accent);
    width: 14px;
    height: 14px;
    cursor: pointer;
  }

  .check-label {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.5;
    transition: color 0.15s;
  }

  .check-label--done {
    color: var(--color-text-tertiary);
    text-decoration: line-through;
  }

  /* ── Phase Status Bar ── */
  .phase-bar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
    flex-wrap: wrap;
  }

  .phase-bar__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-secondary);
  }

  .phase-bar__dot {
    color: var(--color-border-strong);
    font-size: var(--text-xs);
  }

  .phase-bar__detail {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .phase-bar__detail--warn {
    color: #d69e2e;
  }

  .phase-bar__meeting {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    background: var(--color-bg-alt);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  .phase-bar__invoice-status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 1px var(--space-2);
    border-radius: var(--radius-sm);
  }

  .phase-bar__invoice-status--open   { background: #1a2a3a; color: #63b3ed; border: 1px solid #2d4a6a; }
  .phase-bar__invoice-status--paid   { background: #1a3a2a; color: #68d391; border: 1px solid #2d6a4a; }
  .phase-bar__invoice-status--void,
  .phase-bar__invoice-status--uncollectible { background: var(--color-bg-alt); color: var(--color-text-tertiary); border: 1px solid var(--color-border); }

  .phase-bar__signed {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: #38a169;
    font-weight: 600;
  }

  .phase-bar__cta {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: opacity 0.15s;
  }

  .phase-bar__cta:hover { opacity: 0.8; }

  /* ── Wrap-up Stats ── */
  .wrap-stats {
    display: flex;
    gap: var(--space-6);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }

  .wrap-stat__value {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.2;
  }

  .wrap-stat__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
    margin-top: 2px;
  }

  /* Highlighted sidebar card (Call Scheduled next meeting) */
  .card--highlight {
    border-color: var(--color-accent);
    border-width: 1px;
  }

  .card--highlight .card__header h2 {
    color: var(--color-accent);
  }

  /* ── Next Action banner ── */
  .card--next-action {
    border-color: var(--color-accent);
  }

  .next-action-body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding: var(--space-4) var(--space-6);
  }

  .next-action__text {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    flex: 1;
  }

  .next-action-cta {
    flex-shrink: 0;
  }

  /* ── To-Dos ── */
  .todo-add-form {
    margin-bottom: var(--space-4);
  }

  .todo-add-row {
    display: flex;
    gap: var(--space-3);
  }

  .todo-input {
    flex: 1;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    background: var(--color-bg);
    color: var(--color-text);
  }

  .todo-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .todo-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .todo-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    transition: background 0.1s;
  }

  .todo-item:hover {
    background: var(--color-bg-alt);
  }

  .todo-checkbox {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    cursor: pointer;
    accent-color: var(--color-accent);
  }

  .todo-text {
    flex: 1;
    font-size: var(--text-sm);
    color: var(--color-text);
    word-break: break-word;
  }

  .todo-text--done {
    text-decoration: line-through;
    color: var(--color-text-tertiary);
  }

  .todo-delete {
    background: none;
    border: none;
    color: var(--color-text-tertiary);
    font-size: var(--text-base);
    cursor: pointer;
    padding: 0 var(--space-1);
    opacity: 0;
    transition: opacity 0.15s, color 0.15s;
    line-height: 1;
  }

  .todo-item:hover .todo-delete { opacity: 1; }
  .todo-delete:hover { color: #e53e3e; }

  /* ── Work Log ── */
  .work-tabs {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-6);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .work-tab {
    background: none;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    font-weight: 500;
    color: var(--color-text-tertiary);
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: background 0.1s, color 0.1s, border-color 0.1s;
  }

  .work-tab:hover { color: var(--color-text); }

  .work-tab--active {
    background: var(--color-bg-alt);
    color: var(--color-text);
    border-color: var(--color-border);
  }

  .work-status {
    margin-left: auto;
  }

  .work-panel {
    padding: var(--space-4) var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .work-note-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .work-type-select {
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-alt);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .work-textarea {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-sm);
    line-height: 1.6;
    resize: vertical;
    background: var(--color-bg);
    color: var(--color-text);
    box-sizing: border-box;
    transition: border-color 0.15s;
  }

  .work-textarea:focus { outline: none; border-color: var(--color-accent); }

  .work-panel-footer {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-3);
    justify-content: flex-end;
  }

  .work-time-row {
    display: grid;
    grid-template-columns: 130px 90px 1fr;
    gap: var(--space-3);
    align-items: end;
  }

  @media (max-width: 640px) {
    .work-time-row { grid-template-columns: 1fr 1fr; }
    .work-time-desc-col { grid-column: 1 / -1; }
  }

  .work-time-summary {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    flex: 1;
  }

  /* ── Unified Work Feed ── */
  .work-feed {
    display: flex;
    flex-direction: column;
  }

  .feed-entry {
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.1s;
  }

  .feed-entry:last-child { border-bottom: none; }
  .feed-entry:hover { background: var(--color-bg-alt); }

  .feed-entry__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-6) var(--space-2);
  }

  .feed-entry__date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    flex: 1;
  }

  .feed-entry__delete {
    background: none;
    border: none;
    color: var(--color-text-tertiary);
    cursor: pointer;
    font-size: var(--text-sm);
    padding: 0 var(--space-1);
    line-height: 1;
    opacity: 0;
    transition: opacity 0.15s, color 0.15s;
  }

  .feed-entry:hover .feed-entry__delete { opacity: 1; }
  .feed-entry__delete:hover { color: #e53e3e; }

  .feed-entry__body {
    padding: 0 var(--space-6) var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.6;
  }

  /* Activity badge (reused in feed) */
  .activity-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 1px var(--space-2);
    border-radius: var(--radius-sm);
    font-weight: 600;
  }

  .activity-badge--note { background: var(--color-bg); color: var(--color-text-tertiary); border: 1px solid var(--color-border); }
  .activity-badge--call { background: #1a3a2a; color: #68d391; border: 1px solid #2d6a4a; }
  .activity-badge--email { background: #1a2a3a; color: #63b3ed; border: 1px solid #2d4a6a; }

  /* Time badge */
  .time-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    padding: 1px var(--space-2);
    border-radius: var(--radius-sm);
    background: #2a2a1a;
    color: #d4a84b;
    border: 1px solid #4a3a1a;
  }

  /* Client Info sidebar card */
  .ci-row {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: var(--space-3);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
  }

  .ci-row:last-of-type { border-bottom: none; }

  .ci-row--full {
    grid-template-columns: 1fr;
    gap: var(--space-1);
  }

  .ci-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding-top: 2px;
  }

  .ci-value {
