---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import DashboardNav from '../../../components/DashboardNav.astro';
import Stripe from 'stripe';
import { getLeads, type Lead } from '../../../lib/leads';
import { SESSION_COOKIE, SESSION_VALUE, isAuthenticated as checkAuth } from '../../../lib/auth';
import { matchService } from '../../../lib/services';
import { getTimeEntries } from '../../../lib/time';

if (!checkAuth(Astro.cookies)) return Astro.redirect('/dashboard');

let isAuthenticated = true;
let loginError = '';

// Leads from KV
let leads: Lead[] = [];
if (isAuthenticated) {
  try {
    leads = await getLeads();
  } catch {
    leads = [];
  }
}

const stageOrder: Record<string, number> = {
  'Active': 1,
  'Proposal Sent': 2,
  'Call Scheduled': 3,
  'Lead': 4,
  'Closed': 5
};

const activeLeads = leads
  .filter(l => l.stage !== 'Archived')
  .sort((a, b) => (stageOrder[a.stage] ?? 99) - (stageOrder[b.stage] ?? 99));
const archivedLeads = leads.filter(l => l.stage === 'Archived');

// Next upcoming meeting across all active leads
const nowMs = Date.now();
const nextCall = activeLeads
  .filter(l => l.nextMeetingISO && new Date(l.nextMeetingISO).getTime() > nowMs)
  .sort((a, b) => new Date(a.nextMeetingISO!).getTime() - new Date(b.nextMeetingISO!).getTime())[0] ?? null;

// Fetch Stripe invoices per lead
const stripeInvoicesByClient: Record<string, any[]> = {};
if (isAuthenticated && (import.meta.env.STRIPE_SECRET_KEY ?? process.env.STRIPE_SECRET_KEY)) {
  try {
    const stripe = new Stripe(import.meta.env.STRIPE_SECRET_KEY ?? process.env.STRIPE_SECRET_KEY ?? '');
    const stripeLeads = leads.filter(l => l.stripeCustomerId);
    const results = await Promise.allSettled(
      stripeLeads.map(l => stripe.invoices.list({ customer: l.stripeCustomerId, limit: 5 }))
    );
    results.forEach((result, i) => {
      stripeInvoicesByClient[stripeLeads[i].email] =
        result.status === 'fulfilled' ? result.value.data : [];
    });
  } catch {
    // Stripe not configured
  }
}

// ── Revenue widget stats ──
const monthStart = new Date();
monthStart.setDate(1);
monthStart.setHours(0, 0, 0, 0);
const monthStartUnix = Math.floor(monthStart.getTime() / 1000);
const yearStart = new Date(monthStart.getFullYear(), 0, 1);
const yearStartUnix = Math.floor(yearStart.getTime() / 1000);

const proposalLeads = activeLeads.filter(l => l.stage === 'Proposal Sent');
const pipelineValue = proposalLeads.reduce((sum, l) => {
  const svc = matchService(l.serviceInterest ?? '');
  return sum + (svc ? svc.priceCents / 100 : 0);
}, 0);

const clientsActive = activeLeads.filter(l => l.stage === 'Active');
const activeMRR = clientsActive.reduce((sum, l) => {
  const svc = matchService(l.serviceInterest ?? '');
  return sum + (svc?.isRecurring ? svc.priceCents / 100 : 0);
}, 0);

let revenueThisMonth = 0;
let revenueYTD = 0;
if (isAuthenticated && (import.meta.env.STRIPE_SECRET_KEY ?? process.env.STRIPE_SECRET_KEY)) {
  try {
    const stripeR = new Stripe(import.meta.env.STRIPE_SECRET_KEY ?? process.env.STRIPE_SECRET_KEY ?? '');
    const paidInvoices = await stripeR.invoices.list({ status: 'paid', created: { gte: yearStartUnix }, limit: 100 });
    for (const inv of paidInvoices.data) {
      const amt = (inv.amount_paid ?? 0) / 100;
      revenueYTD += amt;
      if (inv.created >= monthStartUnix) revenueThisMonth += amt;
    }
  } catch { /* Stripe not configured */ }
}

function fmt$(n: number): string {
  return n === 0 ? '$0' : '$' + n.toLocaleString('en-US', { maximumFractionDigits: 0 });
}

// ── Pipeline analytics ──
const allLeads = leads;
const proposalPool = allLeads.filter(l => ['Proposal Sent', 'Active', 'Closed'].includes(l.stage));
const wonLeads = allLeads.filter(l => l.stage === 'Active' || l.stage === 'Closed');
const winRate = proposalPool.length > 0 ? Math.round(wonLeads.length / proposalPool.length * 100) : 0;

const stageCounts: Record<string, number> = {};
for (const stage of ['Lead', 'Call Scheduled', 'Proposal Sent', 'Active', 'Closed']) {
  stageCounts[stage] = allLeads.filter(l => l.stage === stage).length;
}

const avgDealSize = wonLeads.length > 0
  ? wonLeads.reduce((sum, l) => {
      const svc = matchService(l.serviceInterest ?? '');
      return sum + (svc ? svc.priceCents / 100 : 0);
    }, 0) / wonLeads.length
  : 0;

// ── Overdue invoices stat (from KV cache written by cron) ──
let overdueCount = 0;
let overdueAmount = 0;
if (isAuthenticated) {
  try {
    const kvToken = import.meta.env.KV_REST_API_TOKEN ?? process.env.KV_REST_API_TOKEN;
    const kvUrl = import.meta.env.KV_REST_API_URL ?? process.env.KV_REST_API_URL;
    if (kvToken && kvUrl) {
      const res = await fetch(`${kvUrl}/get/overdue-cache`, {
        headers: { Authorization: `Bearer ${kvToken}` },
      });
      const json = await res.json() as { result: string | null };
      if (json.result) {
        const val = typeof json.result === 'string' ? JSON.parse(json.result) : json.result;
        overdueCount = val.count ?? 0;
        overdueAmount = val.amount ?? 0;
      }
    }
  } catch { /* cache miss */ }
}

// Fetch time totals for all active leads in parallel
const timeTotalByLeadId: Record<string, number> = {};
if (isAuthenticated) {
  const timeResults = await Promise.allSettled(activeLeads.map(l => getTimeEntries(l.id)));
  timeResults.forEach((r, i) => {
    timeTotalByLeadId[activeLeads[i].id] = r.status === 'fulfilled'
      ? r.value.reduce((sum, e) => sum + e.hours, 0)
      : 0;
  });
}

// ── Command Center Aggregation ──
const globalTodos = activeLeads.flatMap(l => 
  (l.todos ?? []).filter(t => !t.done).map(t => ({ ...t, leadName: l.name, leadId: l.id }))
).sort((a, b) => new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime());

const globalActivity = activeLeads.flatMap(l =>
  (l.activityLog ?? []).map(a => ({ ...a, leadName: l.name, leadId: l.id }))
).sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()).slice(0, 15);
---

<BaseLayout title="Dashboard — Travis Smith" description="Private dashboard">

    <div class="dashboard app-layout">
      <DashboardNav active="clients" leads={activeLeads} />

      <div class="app-main">
      <main class="dashboard-main">
        <div class="container">

          <div class="section-header">
            <h2>Clients</h2>
            <div class="header-actions">
              <button class="btn-secondary" id="new-lead-btn">+ New Lead</button>
              <button class="btn-primary" id="new-invoice-btn">+ New Invoice</button>
            </div>
          </div>

          {activeLeads.length === 0 && archivedLeads.length === 0 ? (
            <section class="section empty-state">
              <p>No leads yet. When someone fills out <strong>/book</strong>, they'll appear here automatically.</p>
            </section>
          ) : (
            <section class="section">
              <div class="table-container">
                <table class="clients-table" id="clients-table">
                  <thead>
                    <tr>
                      <th class="sort-th" data-sort="name">Person <span class="sort-arrow">↕</span></th>
                      <th class="sort-th" data-sort="service">Interested in <span class="sort-arrow">↕</span></th>
                      <th class="sort-th" data-sort="stage">Stage <span class="sort-arrow">↕</span></th>
                      <th class="sort-th" data-sort="invoice">Invoice <span class="sort-arrow">↕</span></th>
                      <th class="sort-th" data-sort="amount">Amount <span class="sort-arrow">↕</span></th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody id="active-leads-body">
                    {activeLeads.map((lead) => {
                      const invoices = stripeInvoicesByClient[lead.email] ?? [];
                      const latest = invoices[0];
                      const statusLabel = latest?.status ?? '—';
                      const amount = latest ? `$${((latest.amount_due ?? 0) / 100).toFixed(2)}` : '—';
                      const invoiceUrl = latest?.hosted_invoice_url ?? null;
                      return (
                        <tr
                          data-lead-id={lead.id}
                          data-href={`/dashboard/${lead.id}`}
                          class="clickable-row"
                          data-sort-name={lead.name.toLowerCase()}
                          data-sort-service={(lead.serviceInterest ?? '').replace(/\s*\(\$[\d,]+(?:\/\w+)?\)/g, '').toLowerCase()}
                          data-sort-stage={String(stageOrder[lead.stage] ?? 99)}
                          data-sort-invoice={(stripeInvoicesByClient[lead.email]?.[0]?.status ?? 'zzz').toLowerCase()}
                          data-sort-amount={String((stripeInvoicesByClient[lead.email]?.[0]?.amount_due ?? 0) / 100)}
                        >
                          <td>
                            <a href={`/dashboard/${lead.id}`} class="client-name-link">
                              <div class="client-name">{lead.name}</div>
                              <div class="client-email">{lead.email}</div>
                              {lead.storeUrl && <div class="client-store">{lead.storeUrl.replace(/^https?:\/\//, '')}</div>}
                              {lead.nextMeeting && <div class="client-meeting">📅 {lead.nextMeeting}</div>}
                              {(timeTotalByLeadId[lead.id] ?? 0) > 0 && (
                                <div class="client-time">{timeTotalByLeadId[lead.id].toFixed(1)} hrs logged</div>
                              )}
                            </a>
                          </td>
                          <td>
                            <div class="service-interest">
                              {lead.serviceInterest ? lead.serviceInterest.replace(/\s*\(\$[\d,]+(?:\/\w+)?\)/g, '') : '—'}
                              {lead.storeStatus && <span class="store-status-sep"> · {lead.storeStatus}</span>}
                            </div>
                          </td>
                          <td>
                            <span class={`stage-badge stage-${lead.stage.toLowerCase().replace(/\s+/g, '-')}`}>
                              {lead.stage}
                            </span>
                          </td>
                          <td>
                            {invoiceUrl ? (
                              <a href={invoiceUrl} target="_blank" rel="noopener" class={`invoice-status status-${statusLabel}`}>
                                {statusLabel}
                              </a>
                            ) : (
                              <span class="invoice-status status-none">{statusLabel}</span>
                            )}
                          </td>
                          <td class="mono">{amount}</td>
                          <td class="td-actions">
                            <div class="row-menu">
                              <button class="row-menu-btn" aria-label="Actions" aria-expanded="false">⋮</button>
                              <div class="row-menu-dropdown" hidden>
                                <button class="row-menu-item followup-btn" data-email={lead.email} data-name={lead.name} data-invoice-url={invoiceUrl ?? ''}>Follow up</button>
                                <button class="row-menu-item archive-btn" data-lead-id={lead.id}>Archive</button>
                                <button class="row-menu-item row-menu-item--danger delete-btn" data-lead-id={lead.id} data-name={lead.name}>Delete</button>
                              </div>
                            </div>
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                  {archivedLeads.length > 0 && (
                    <tbody id="archived-leads-body" class="archived-section" hidden>
                      <tr class="archived-divider">
                        <td colspan="6">Archived</td>
                      </tr>
                      {archivedLeads.map((lead) => (
                        <tr data-lead-id={lead.id} class="archived-row">
                          <td>
                            <a href={`/dashboard/${lead.id}`} class="client-name-link">
                              <div class="client-name">{lead.name}</div>
                              <div class="client-email">{lead.email}</div>
                            </a>
                          </td>
                          <td><div class="service-interest">{lead.serviceInterest ? lead.serviceInterest.replace(/\s*\(\$[\d,]+(?:\/\w+)?\)/g, '') : '—'}</div></td>
                          <td><span class="stage-badge stage-archived">Archived</span></td>
                          <td>—</td>
                          <td>—</td>
                          <td class="td-actions">
                            <div class="row-menu">
                              <button class="row-menu-btn" aria-label="Actions" aria-expanded="false">⋮</button>
                              <div class="row-menu-dropdown" hidden>
                                <button class="row-menu-item restore-btn" data-lead-id={lead.id}>Restore</button>
                                <button class="row-menu-item row-menu-item--danger delete-btn" data-lead-id={lead.id} data-name={lead.name}>Delete</button>
                              </div>
                            </div>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  )}
                </table>
              </div>
              {archivedLeads.length > 0 && (
                <div class="archived-toggle-row">
                  <button class="archived-toggle" id="archived-toggle">
                    Show archived ({archivedLeads.length})
                  </button>
                </div>
              )}
            </section>
          )}

        </div>
      </main>
      </div>
    </div>

  <!-- ═══════════════════════════════════════════
       NEW INVOICE MODAL
  ════════════════════════════════════════════ -->
  <div id="invoice-modal" class="modal" aria-hidden="true">
    <div class="modal-backdrop"></div>
    <div class="modal-dialog">
      <div class="modal-header">
        <h2>New Invoice</h2>
        <button class="modal-close" aria-label="Close">&times;</button>
      </div>
      <form id="invoice-form" class="modal-body">
        <div class="form-row">
          <label for="inv-name">Client Name</label>
          <input type="text" id="inv-name" name="clientName" required placeholder="Jane Founder" />
        </div>
        <div class="form-row">
          <label for="inv-email">Client Email</label>
          <input type="email" id="inv-email" name="clientEmail" required placeholder="jane@example.com" />
        </div>
        <div class="form-row">
          <label for="inv-service">Service</label>
          <select id="inv-service" name="service">
            <option value="Clarity Session">Clarity Session</option>
            <option value="Store Launch Sprint">Store Launch Sprint</option>
            <option value="Insider Retainer">Insider Retainer</option>
            <option value="Free Month">Free Month</option>
            <option value="Custom">Custom</option>
          </select>
        </div>
        <div class="form-row">
          <label for="inv-amount">Amount (USD)</label>
          <input type="number" id="inv-amount" name="amount" required min="1" step="0.01" placeholder="500" />
        </div>
        <div class="form-row">
          <label for="inv-desc">Description</label>
          <textarea id="inv-desc" name="description" rows="3" placeholder="90-min store audit + written action plan"></textarea>
        </div>
        <div id="invoice-feedback" class="form-feedback"></div>
        <div class="modal-actions">
          <button type="button" class="btn-secondary modal-close-btn">Cancel</button>
          <button type="submit" class="btn-primary" id="send-invoice-btn">Send Invoice</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       FOLLOW-UP MODAL
  ════════════════════════════════════════════ -->
  <div id="followup-modal" class="modal" aria-hidden="true">
    <div class="modal-backdrop"></div>
    <div class="modal-dialog">
      <div class="modal-header">
        <h2>Send Follow-up</h2>
        <button class="modal-close-followup" aria-label="Close">&times;</button>
      </div>
      <form id="followup-form" class="modal-body">
        <div class="form-row">
          <label for="fu-to">To</label>
          <input type="email" id="fu-to" name="to" required />
        </div>
        <div class="form-row">
          <label for="fu-subject">Subject</label>
          <input type="text" id="fu-subject" name="subject" required value="Quick note from Travis" />
        </div>
        <div class="form-row">
          <label for="fu-body">Message</label>
          <textarea id="fu-body" name="body" rows="6" required></textarea>
        </div>
        <div id="followup-feedback" class="form-feedback"></div>
        <div class="modal-actions">
          <button type="button" class="btn-secondary modal-close-followup-btn">Cancel</button>
          <button type="submit" class="btn-primary">Send Email</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       NEW LEAD MODAL
  ════════════════════════════════════════════ -->
  <div id="new-lead-modal" class="modal" aria-hidden="true">
    <div class="modal-backdrop"></div>
    <div class="modal-dialog">
      <div class="modal-header">
        <h2>New Lead</h2>
        <button class="modal-close-lead" aria-label="Close">&times;</button>
      </div>
      <form id="new-lead-form" class="modal-body">
        <div class="form-row">
          <label for="nl-name">Name *</label>
          <input type="text" id="nl-name" name="name" required placeholder="Jane Founder" />
        </div>
        <div class="form-row">
          <label for="nl-email">Email *</label>
          <input type="email" id="nl-email" name="email" required placeholder="jane@example.com" />
        </div>
        <div class="form-row">
          <label for="nl-service">Service Interest</label>
          <select id="nl-service" name="serviceInterest">
            <option value="">— not set —</option>
            <option value="Clarity Session">Clarity Session ($500)</option>
            <option value="Store Launch Sprint">Store Launch Sprint ($2,500)</option>
            <option value="Insider Retainer">Insider Retainer ($3,500/mo)</option>
            <option value="Free Month">Free Month (10-15 hrs)</option>
          </select>
        </div>
        <div class="form-row">
          <label for="nl-stage">Stage</label>
          <select id="nl-stage" name="stage">
            <option value="Lead">Lead</option>
            <option value="Call Scheduled">Call Scheduled</option>
            <option value="Proposal Sent">Proposal Sent</option>
            <option value="Active">Active</option>
          </select>
        </div>
        <div class="form-row">
          <label for="nl-store">Store URL</label>
          <input type="text" id="nl-store" name="storeUrl" placeholder="example.myshopify.com" />
        </div>
        <div class="form-row">
          <label for="nl-notes">Notes</label>
          <textarea id="nl-notes" name="notes" rows="3" placeholder="How they found you, what they need..."></textarea>
        </div>
        <div id="new-lead-feedback" class="form-feedback"></div>
        <div class="modal-actions">
          <button type="button" class="btn-secondary modal-close-lead-btn">Cancel</button>
          <button type="submit" class="btn-primary">Add Lead</button>
        </div>
      </form>
    </div>
  </div>

</BaseLayout>

<style>
  /* ── Auth ── */
  .auth-screen {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-alt);
  }

  .auth-card {
    background: var(--color-bg);
    padding: var(--space-12);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    text-align: center;
    max-width: 400px;
    width: 100%;
  }

  .auth-card h1 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-2);
  }

  .auth-card p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .auth-card form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .auth-card input {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    font-family: inherit;
  }

  .auth-card button {
    padding: var(--space-3) var(--space-6);
    background: var(--color-accent);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    font-family: inherit;
    font-weight: 500;
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease);
  }

  .auth-card button:hover {
    background: var(--color-accent-hover);
  }

  .error {
    color: #e53e3e;
    font-size: var(--text-sm);
    margin-top: var(--space-4);
  }

  /* ── Dashboard shell ── */
  .dashboard {
    min-height: 100vh;
    background: var(--color-bg-alt);
  }

  /* ── Buttons ── */
  .btn-primary {
    padding: var(--space-2) var(--space-4);
    background: var(--color-accent);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease);
    line-height: 1.5;
  }

  .btn-primary:hover { background: var(--color-accent-hover); }

  .btn-secondary {
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-sm);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease);
    line-height: 1.5;
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* ── Dashboard main ── */
  .dashboard-main {
    padding: var(--space-8) 0 var(--space-12);
  }

  /* ── Next Call card ── */
  .next-call-card {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-4) var(--space-6);
    background: var(--color-bg);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-6);
    text-decoration: none;
    transition: background 0.15s;
  }

  .next-call-card:hover {
    background: var(--color-bg-alt);
  }

  .next-call-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .next-call-info {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .next-call-name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .next-call-dot {
    color: var(--color-text-tertiary);
  }

  .next-call-time {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  /* ── Stats strip ── */
  .stats-strip {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  @media (max-width: 768px) {
    .stats-strip { grid-template-columns: repeat(2, 1fr); }
  }

  .stat-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5) var(--space-5);
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-1);
  }

  .stat-value {
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.1;
    margin-bottom: 4px;
  }

  .stat-sub {
