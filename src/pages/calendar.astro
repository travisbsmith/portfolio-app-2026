---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import DashboardNav from '../components/DashboardNav.astro';
import { getLeads } from '../lib/leads';
import { SESSION_COOKIE, SESSION_VALUE } from '../lib/auth';

const isAuthenticated = Astro.cookies.get(SESSION_COOKIE)?.value === SESSION_VALUE;
if (!isAuthenticated) return Astro.redirect('/dashboard');

const leads = await getLeads();
const now = Date.now();

// All leads with a future meeting, sorted ascending
const upcoming = leads
  .filter(l => {
    if (l.nextMeetingISO) return new Date(l.nextMeetingISO).getTime() > now;
    return !!l.nextMeeting;
  })
  .sort((a, b) => {
    const tA = a.nextMeetingISO ? new Date(a.nextMeetingISO).getTime() : 0;
    const tB = b.nextMeetingISO ? new Date(b.nextMeetingISO).getTime() : 0;
    if (tA === 0 && tB === 0) return 0;
    if (tA === 0) return 1;
    if (tB === 0) return -1;
    return tA - tB;
  });

// Group by ISO week (YYYY-Www)
function isoWeek(dateStr: string): string {
  const d = new Date(dateStr);
  const jan4 = new Date(d.getFullYear(), 0, 4);
  const dayOfYear = Math.floor((d.getTime() - new Date(d.getFullYear(), 0, 0).getTime()) / 86400000);
  const weekNum = Math.ceil((dayOfYear + jan4.getDay()) / 7);
  return `${d.getFullYear()}-W${String(weekNum).padStart(2, '0')}`;
}

function weekLabel(isoWeekStr: string): string {
  if (isoWeekStr === 'Manual') return 'Manually Scheduled';
  // Parse YYYY-Www and return "Week of Mon D"
  const [yearStr, wStr] = isoWeekStr.split('-W');
  const year = parseInt(yearStr);
  const week = parseInt(wStr);
  // ISO week 1 starts on the Monday containing Jan 4
  const jan4 = new Date(year, 0, 4);
  const mondayOfWeek1 = new Date(jan4.getTime() - (jan4.getDay() === 0 ? 6 : jan4.getDay() - 1) * 86400000);
  const weekStart = new Date(mondayOfWeek1.getTime() + (week - 1) * 7 * 86400000);
  return 'Week of ' + weekStart.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

// Build grouped structure: Map<weekKey, entries[]>
const grouped = new Map<string, typeof upcoming>();
for (const lead of upcoming) {
  const key = lead.nextMeetingISO ? isoWeek(lead.nextMeetingISO) : 'Manual';
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(lead);
}

const stageBadgeColor: Record<string, string> = {
  'Lead': '#718096',
  'Call Scheduled': '#4a90d9',
  'Proposal Sent': '#d69e2e',
  'Active': '#38a169',
  'Closed': '#718096',
  'Archived': '#718096',
};
---

<BaseLayout title="Calendar — Dashboard" description="Upcoming client meetings">
<div class="cal-page app-layout">
  <DashboardNav active="calendar" leads={leads.filter(l => l.stage !== 'Archived')} />

  <div class="app-main">
  <div class="container">
    <div class="cal-header">
      <h1 class="cal-title">Upcoming Meetings</h1>
      <span class="cal-count">{upcoming.length} scheduled</span>
    </div>

    {upcoming.length === 0 ? (
      <div class="cal-empty">
        <p>No upcoming meetings scheduled.</p>
      </div>
    ) : (
      <div class="cal-weeks">
        {[...grouped.entries()].map(([weekKey, entries]) => (
          <section class="cal-week">
            <div class="cal-week__label">{weekLabel(weekKey)}</div>
            <div class="cal-week__rows">
              {entries.map(lead => {
                const meetingDate = lead.nextMeetingISO ? new Date(lead.nextMeetingISO) : null;
                const dayStr = meetingDate ? meetingDate.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) : 'Set manually';
                const timeStr = meetingDate ? meetingDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', timeZoneName: 'short' }) : (lead.nextMeeting || 'TBD');
                const stageColor = stageBadgeColor[lead.stage] ?? '#718096';
                return (
                  <a href={`/dashboard/${lead.id}`} class="cal-row">
                    <div class="cal-row__datetime">
                      <span class="cal-row__day">{dayStr}</span>
                      <span class="cal-row__time">{timeStr}</span>
                    </div>
                    <div class="cal-row__client">
                      <span class="cal-row__name">{lead.name}</span>
                      <span class="cal-row__service">{lead.serviceInterest}</span>
                    </div>
                    <div class="cal-row__meta">
                      <span class="cal-row__stage" style={`background: ${stageColor}22; color: ${stageColor};`}>{lead.stage}</span>
                      {lead.calBookingUid && (
                        <a
                          href={`https://cal.com/booking/${lead.calBookingUid}`}
                          target="_blank"
                          rel="noopener"
                          class="cal-row__cal-link"
                          onclick="event.stopPropagation()"
                        >Cal.com ↗</a>
                      )}
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        ))}
      </div>
    )}
  </div>
  </div>
  </div>
</div>
</BaseLayout>

<style>
  .cal-page {
    min-height: 100vh;
    background: var(--color-bg-alt);
    padding: var(--space-8) 0;
  }

  .cal-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .cal-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text);
  }

  .cal-count {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .cal-empty {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    text-align: center;
    color: var(--color-text-tertiary);
    font-size: var(--text-sm);
  }

  .cal-weeks {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .cal-week__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-3);
  }

  .cal-week__rows {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cal-row {
    display: grid;
    grid-template-columns: 180px 1fr auto;
    align-items: center;
    gap: var(--space-6);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .cal-row:hover {
    border-color: var(--color-accent);
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }

  .cal-row__datetime {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cal-row__day {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .cal-row__time {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .cal-row__client {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cal-row__name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .cal-row__service {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .cal-row__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .cal-row__stage {
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  .cal-row__cal-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-decoration: none;
    white-space: nowrap;
  }

  .cal-row__cal-link:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .cal-row {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }
</style>
